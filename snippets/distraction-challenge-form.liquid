{% comment %}
  90-Day Kill Your Distraction Challenge
  File: sections/distraction-challenge-form.liquid
  Complete waitlist form with all fields
{% endcomment %}

<div class="contact-form-section-wrapper">
  <div class="contact-form-container">
    <section class="contact-form-content-area">
      <h1 class="contact-form-heading">{{ section.settings.main_heading }}</h1>
      <p class="contact-form-description">{{ section.settings.subtitle }}</p>
      
      <div class="contact-form-wrapper">
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="contact-form-success-msg contact-form-active">
              <div class="contact-form-success-icon">✓</div>
              <h3 class="contact-form-success-title">Thank You!</h3>
              <p class="contact-form-success-text">
                Your information has been submitted successfully. Welcome to the waitlist!
              </p>
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="contact-form-error-msg">
              <p><strong>Please fix the following errors:</strong></p>
              <ul>
                {% for field in form.errors %}
                  <li>{{ field | capitalize }}: {{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <h2 class="contact-form-section-title">Your Information</h2>
          
          <div class="contact-form-row">
            <div class="contact-form-group">
              <label for="contactFormFirstName" class="contact-form-label">First Name *</label>
              <input type="text" id="contactFormFirstName" name="contact[First Name]" class="contact-form-input" required />
            </div>

            <div class="contact-form-group">
              <label for="contactFormLastName" class="contact-form-label">Last Name *</label>
              <input type="text" id="contactFormLastName" name="contact[Last Name]" class="contact-form-input" required />
            </div>
          </div>

          <div class="contact-form-row">
            <div class="contact-form-group">
              <label for="contactFormEmail" class="contact-form-label">Email Address *</label>
              <input type="email" id="contactFormEmail" name="contact[email]" class="contact-form-input" required />
            </div>

            <div class="contact-form-group">
              <label for="contactFormPhone" class="contact-form-label">Phone Number *</label>
              <input type="tel" id="contactFormPhone" name="contact[Phone Number]" class="contact-form-input" required />
            </div>
          </div>

          <h2 class="contact-form-section-title">Your Distraction Challenge</h2>

          <div class="contact-form-group">
            <label for="contactFormDistraction" class="contact-form-label">What is your biggest distraction right now? *</label>
            <input type="text" id="contactFormDistraction" name="contact[Biggest Distraction]" class="contact-form-input" required />
          </div>

          <div class="contact-form-group">
            <label for="contactFormScale" class="contact-form-label">
              On a scale of 1 to 10, how distracted do you feel on a daily basis? *
            </label>
            <p class="scale-description">On a scale of 1 to 10, where 1 means 'not distracted at all' and 10 means 'extremely distracted'</p>
            <div class="range-slider-wrapper">
              <span class="range-value">0</span>
              <input 
                type="range" 
                id="contactFormScale" 
                name="contact[Distraction Level]" 
                class="range-slider" 
                min="0" 
                max="100" 
                value="0"
                oninput="updateRangeValue(this.value)"
              />
              <span class="range-value">100</span>
            </div>
            <input type="hidden" id="distractionLevelValue" name="contact[Distraction Level Value]" value="0" />
          </div>

          <div class="contact-form-group">
            <label class="contact-form-label">Are you ready to commit to 90 days of focus and discipline? *</label>
            <div class="commitment-buttons">
              <button type="button" class="commitment-btn" onclick="selectCommitment(this, 'YES')">YES</button>
              <button type="button" class="commitment-btn" onclick="selectCommitment(this, 'NO')">NO</button>
            </div>
            <input type="hidden" id="commitmentValue" name="contact[90 Day Commitment]" value="" required />
          </div>

          <button type="submit" class="contact-form-submit-btn">Join the Waitlist!</button>
        {% endform %}
      </div>
    </section>
  </div>
</div>

<style>
  * {
    box-sizing: border-box;
  }

  .contact-form-section-wrapper {
    width: 100%;
    background-color: #f5f7fa;
    padding: 60px 0;
  }

  .contact-form-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .contact-form-content-area {
    background-color: #ffffff;
    padding: 50px 50px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .contact-form-heading {
    font-size: 2rem;
    margin: 0 0 12px 0;
    color: #2563eb;
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
  }

  .contact-form-description {
    font-size: 1rem;
    margin: 0 auto 40px;
    color: #6b7280;
    max-width: 600px;
    line-height: 1.6;
    text-align: center;
  }

  .contact-form-wrapper {
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-form-section-title {
    font-size: 1.5rem;
    margin: 30px 0 20px 0;
    color: #2563eb;
    font-weight: 700;
  }

  .contact-form-row {
    display: flex;
    gap: 20px;
    margin-bottom: 0;
  }

  .contact-form-group {
    flex: 1;
    margin-bottom: 24px;
    text-align: left;
  }

  .contact-form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #1f2937;
    font-size: 0.95rem;
  }

  .contact-form-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 1rem;
    transition: all 0.2s ease;
    font-family: inherit;
    background-color: #ffffff;
    color: #1f2937;
  }

  .contact-form-input:focus {
    outline: none;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .contact-form-input::placeholder {
    color: #9ca3af;
  }

  .scale-description {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 4px 0 16px 0;
    line-height: 1.5;
  }

  .range-slider-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 12px;
  }

  .range-value {
    color: #2563eb;
    font-weight: 700;
    font-size: 1rem;
    min-width: 35px;
    text-align: center;
  }

  .range-slider {
    flex: 1;
    height: 8px;
    -webkit-appearance: none;
    appearance: none;
    background: #e5e7eb;
    border-radius: 4px;
    outline: none;
    cursor: pointer;
  }

  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    background: #2563eb;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .range-slider::-webkit-slider-thumb:hover {
    background: #1d4ed8;
    transform: scale(1.1);
  }

  .range-slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    background: #2563eb;
    border-radius: 50%;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
  }

  .range-slider::-moz-range-thumb:hover {
    background: #1d4ed8;
    transform: scale(1.1);
  }

  .commitment-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 12px;
  }

  .commitment-btn {
    padding: 14px 24px;
    background: #ffffff;
    border: 2px solid #d1d5db;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: #1f2937;
    transition: all 0.2s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .commitment-btn:hover {
    border-color: #2563eb;
    background: #eff6ff;
    color: #2563eb;
  }

  .commitment-btn.active {
    background: #2563eb;
    color: #ffffff;
    border-color: #2563eb;
  }

  .contact-form-submit-btn {
    width: 100%;
    background-color: #2563eb;
    color: #ffffff;
    padding: 16px;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 700;
    text-transform: none;
    letter-spacing: 0.3px;
    margin-top: 32px;
  }

  .contact-form-submit-btn:hover {
    background-color: #1d4ed8;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
  }

  .contact-form-error-msg {
    background-color: #fef2f2;
    border: 2px solid #ef4444;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 24px;
    color: #991b1b;
  }

  .contact-form-error-msg p {
    margin: 0 0 10px 0;
    font-weight: 600;
  }

  .contact-form-error-msg ul {
    margin: 0;
    padding-left: 20px;
  }

  .contact-form-error-msg li {
    margin: 5px 0;
  }

  .contact-form-success-msg {
    text-align: center;
    padding: 40px 30px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border: 2px solid #2563eb;
    border-radius: 12px;
    margin-bottom: 30px;
    display: none;
  }

  .contact-form-success-msg.contact-form-active {
    display: block;
  }

  .contact-form-success-icon {
    width: 70px;
    height: 70px;
    background-color: #2563eb;
    color: #ffffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    margin: 0 auto 20px;
    font-weight: bold;
  }

  .contact-form-success-title {
    color: #1e40af;
    margin: 0 0 15px 0;
    font-size: 2rem;
    font-weight: 700;
  }

  .contact-form-success-text {
    color: #1e40af;
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .contact-form-section-wrapper {
      padding: 40px 0;
    }

    .contact-form-content-area {
      padding: 40px 30px;
    }

    .contact-form-heading {
      font-size: 1.75rem;
    }

    .contact-form-description {
      font-size: 0.95rem;
    }

    .contact-form-section-title {
      font-size: 1.3rem;
    }

    .contact-form-row {
      flex-direction: column;
      gap: 0;
    }

    .commitment-buttons {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .contact-form-section-wrapper {
      padding: 30px 0;
    }

    .contact-form-content-area {
      padding: 30px 20px;
    }

    .contact-form-heading {
      font-size: 1.5rem;
    }

    .contact-form-description {
      font-size: 0.9rem;
    }

    .contact-form-section-title {
      font-size: 1.2rem;
      margin: 25px 0 15px 0;
    }

    .range-slider-wrapper {
      gap: 12px;
    }

    .range-value {
      font-size: 0.9rem;
      min-width: 30px;
    }

    .commitment-buttons {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .commitment-btn {
      padding: 12px 16px;
      font-size: 0.95rem;
    }

    .contact-form-submit-btn {
      font-size: 1rem;
      padding: 14px;
    }
  }
</style>

<script>
  function updateRangeValue(value) {
    document.getElementById('distractionLevelValue').value = value;
  }

  function selectCommitment(button, value) {
    const buttons = button.parentElement.querySelectorAll('.commitment-btn');
    buttons.forEach(btn => btn.classList.remove('active'));
    button.classList.add('active');
    document.getElementById('commitmentValue').value = value;
  }

  document.addEventListener('DOMContentLoaded', function() {
    const rangeInput = document.getElementById('contactFormScale');
    if (rangeInput) {
      updateRangeValue(rangeInput.value);
    }
  });
</script>