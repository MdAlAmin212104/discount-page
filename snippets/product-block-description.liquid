{%- if product.description != blank and enable_collapsible_tabs or truncate_description -%}
  {%- if enable_collapsible_tabs -%}
    <div class="js-enabled accordian mt-8 {{ block.shopify_attributes }}" style="color: black;">
      {%- liquid
        assign description_parts = product.description | replace: '<h2 data-mce-fragment="1">', '<h2>' | split: '<h2>'
        assign counter = 1
      -%}
      {% for part in description_parts %}
          {% unless part == blank %}
          {% if part contains '</h2>' %}
            {% assign part_parts = part | split: '</h2>' %}
            {% assign heading_handle = part_parts.first | handle %}
            <div class="{% if counter == 1 %}mt-8{% endif %} -mx-2 lg:-mx-4 section-x-padding py-2 border-t-grid border-theme-color {% if forloop.last %}border-b-grid{% endif %}" 
                 x-data="{ open: false }" 
                 x-cloak 
                 style="color: black;">
              <h2 class="{{ settings.base_heading_size }}" style="color: black;">
                <button @click="open = !open" 
                        class="font-heading cursor-pointer flex justify-between items-center w-full" 
                        :aria-expanded="open ? true : 'false'" 
                        style="color: black;">
                  {{ part_parts.first }}
                  <span class="inline-block w-5 h-5" x-show="!open">{%- render 'icon-plus' %}</span>
                  <span class="inline-block w-5 h-5" x-show="open">{%- render 'icon-minus' %}</span>
                </button>
              </h2>
              <div class="py-4 rte" x-show="open" id="{{ heading_handle }}" style="color: black;">
                {{ part_parts.last }}
              </div>
            </div>
            {% assign counter = counter | plus: 1 %}
          {% else %}
          <div class="rte" style="color: black;">
            {{ part }}
          </div>
          {% endif %}
        {% endunless %}
      {% endfor %}
    </div>
  {%- else -%}
    <div class="js-enabled mt-8 {{ block.shopify_attributes }}" x-cloak style="color: black;">
      <div class="rte" x-show="!showFullDescription" x-html="truncatedProductDescription" style="color: black;"></div>
      <button @click="showFullDescription = !showFullDescription" 
              x-show="!showFullDescription" 
              :aria-expanded="showFullDescription ? true : 'false'" 
              class="mt-4 inline-flex justify-start items-center hover:text-scheme-accent text-base items-center justify-center {% if settings.links_show_underline %}border-b-text border-scheme-text hover:border-scheme-accent pb-1{% endif %} cursor-pointer" 
              style="color: black;">
        <span class="{% if settings.links_uppercase %}uppercase{% endif %}" style="color: black;">
          {{ 'products.product.read_more' | t }}
        </span>
        <span class="inline-block w-5 h-5 ml-2" style="color: black;">{%- render 'icon-plus' %}</span>
      </button>
      <div class="rte" x-show="showFullDescription" style="color: black;">
        {{ product.description }}
      </div>
    </div>
  {%- endif -%}
  <noscript>
    <div class="rte mt-8" style="color: black;">
      {{ product.description }}
    </div>
  </noscript>
{%- else -%}
  <div class="rte mt-8 {{ block.shopify_attributes }}" style="color: black;">
    {{ product.description }}
  </div>
{%- endif -%}
