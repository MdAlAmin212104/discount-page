                      <path d="M7.16319 9.72332L9.1148 9.14576L9.89457 11.885L7.16319 9.72332ZM11.588 6.26351H8.20604L7.16319 2.80371L6.12023 6.26351H2.73828L5.46966 8.42521L4.42681 11.885L7.15819 9.72332L8.84671 8.42521L11.588 6.26351Z" fill="white"/>
                    </svg>
                    <svg width="14" height="15" viewBox="0 0 14 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M13.4049 0.499023H0.919922V14.3272H13.4049V0.499023Z" fill="#00B67A"/>
                      <path d="M7.16319 9.72332L9.1148 9.14576L9.89457 11.885L7.16319 9.72332ZM11.588 6.26351H8.20604L7.16319 2.80371L6.12023 6.26351H2.73828L5.46966 8.42521L4.42681 11.885L7.15819 9.72332L8.84671 8.42521L11.588 6.26351Z" fill="white"/>
                    </svg>
                    <svg width="14" height="15" viewBox="0 0 14 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M13.4049 0.499023H0.919922V14.3272H13.4049V0.499023Z" fill="#00B67A"/>
                      <path d="M7.16319 9.72332L9.1148 9.14576L9.89457 11.885L7.16319 9.72332ZM11.588 6.26351H8.20604L7.16319 2.80371L6.12023 6.26351H2.73828L5.46966 8.42521L4.42681 11.885L7.15819 9.72332L8.84671 8.42521L11.588 6.26351Z" fill="white"/>
                    </svg>
                  </div>
                  <span class="customers">4.8 / 5</span>
                </div>
                <div class="info-item">
                  <span class="returns">100,000+ customers</span>
                </div>
              </div>
              <div class="text-right">
                <div>
                  <input
                    type="submit"
                    name="checkout"
                    class="cursor-pointer py-2 px-4 w-full {% render 'button-style', section_color: section_color %} {% render 'button-color', section_color: section_color %}"
                    :disabled="updating"
                    value="Secure Checkout 🔒"
                    
                  >
                </div>
                <p style="text-align:center; font-size:12px; margin-top:8px; color:#666;">
  Free returns • Easy exchanges • Free express shipping today
</p>
                {% if additional_checkout_buttons and settings.cart_additional_buttons %}
                  <div class="w-full md:mt-2 additional-checkout-buttons {% render 'button-style' %}">
                    {{ content_for_additional_checkout_buttons }}
                  </div>
                {% endif %}
                <ul class="flex justify-center items-center gap-1">
                  <li>
                    <svg
                      class="h-4 w-auto"
                      xmlns="http://www.w3.org/2000/svg"
                      role="img"
                      aria-labelledby="pi-american_express"
                      viewBox="0 0 38 24"
                      width="38"
                      height="24"
                    >
