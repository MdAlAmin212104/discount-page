                      xmlns="http://www.w3.org/2000/svg"
                      role="img"
                      x="0"
                      y="0"
                      width="38"
                      height="24"
                      viewBox="0 0 165.521 105.965"
                      xml:space="preserve"
                      aria-labelledby="pi-apple_pay"
