   .dot1 {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: red;
  position: relative;
  animation: blink 1.5s infinite;
}
   /* Pulse animation using pseudo-element */
.dot1::before {
  content: '';
  position: absolute;
  top: -5px;
  left: -5px;
  width: 20px;
  height: 20px;
  background: rgba(255, 0, 0, 0.5);
  border-radius: 50%;
  animation: pulse 1.5s infinite;
  z-index: -1;
}

/* Blinking animation */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* Pulsing animation */
@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.4);
    opacity: 0.2;
  }
  100% {
    transform: scale(0.8);
    opacity: 0.6;
  }
}

