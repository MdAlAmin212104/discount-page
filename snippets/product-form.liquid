<script>
  console.log('Notify script loaded');
  function openNotifyPopup() {
    console.log('Opening popup');
    var popup = document.getElementById('notifyPopup');
    if (popup) {
      popup.classList.add('active');
    } else {
      console.error('Popup element not found');
    }
  }

  function closeNotifyPopup() {
    console.log('Closing popup');
    var popup = document.getElementById('notifyPopup');
    if (popup) {
      popup.classList.remove('active');
    }
  }

  function submitNotifyForm(event) {
    event.preventDefault();
    console.log('Form submitted');
    var email = document.getElementById('notifyEmail').value.trim();
    if (!email) {
      console.log('Email field is empty, stopping');
      return; // Do nothing if email is empty
    }
    console.log('Email:', email);
    alert('Thank you! We will notify you when this product is available.');
    closeNotifyPopup();
    document.getElementById('notifyForm').reset();
  }
</script>