        "title": "",
        "subheading": "",
        "custom_liquid": "<body>\n    <div class=\"challengeFormWrapper\">\n      <h1 class=\"challengeFormTitle\">90-Day Kill Your Distraction Challenge</h1>\n      <p class=\"challengeFormSubtitle\">\n        Join the waitlist and start your transformation.\n      </p>\n\n      <h3 class=\"challengeFormSectionTitle\">Your Information</h3>\n      <form id=\"challengeForm\">\n        <label for=\"firstName\" class=\"challengeFormLabel\">First Name*</label>\n        <input\n          type=\"text\"\n          id=\"firstName\"\n          name=\"firstName\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your Name\"\n        />\n\n        <label for=\"lastName\" class=\"challengeFormLabel\">Last Name*</label>\n        <input\n          type=\"text\"\n          id=\"lastName\"\n          name=\"lastName\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Last name\"\n        />\n\n        <label for=\"email\" class=\"challengeFormLabel\">Email Address*</label>\n        <input\n          type=\"email\"\n          id=\"email\"\n          name=\"email\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your email address\"\n        />\n\n        <label for=\"phone\" class=\"challengeFormLabel\">Phone Number*</label>\n        <input\n          type=\"tel\"\n          id=\"phone\"\n          name=\"phone\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your phone number\"\n        />\n\n        <h3 class=\"challengeFormSectionTitle\">Your Distraction Challenge</h3>\n\n        <label for=\"distraction\" class=\"challengeFormLabel\">\n          What is your biggest distraction right now?*\n        </label>\n        <input\n          type=\"text\"\n          id=\"distraction\"\n          name=\"distraction\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Social media, smartphone, TV, etc.\"\n        />\n\n        <p class=\"challengeFormParagraph\">\n          On a scale of 1 to 100, how distracted do you feel daily?*\n          <span id=\"scaleValueDisplay\">0</span>\n        </p>\n        <div class=\"challengeRangeWrapper\">\n          <span>0</span>\n          <input\n            type=\"range\"\n            id=\"scale\"\n            name=\"scale\"\n            min=\"0\"\n            max=\"100\"\n            value=\"0\"\n            class=\"challengeRangeInput\"\n            oninput=\"document.getElementById('scaleValueDisplay').textContent = this.value\"\n          />\n          <span>100</span>\n        </div>\n\n        <label class=\"challengeFormLabel\" style=\"margin: 24px 0px 12px\">\n          Are you ready to commit to 90 days of focus and discipline?*\n        </label>\n        <div class=\"challengeCommitWrapper\">\n          <button\n            type=\"button\"\n            class=\"challengeCommitBtn\"\n            onclick=\"selectCommitment(this, 'YES')\"\n          >\n            YES\n          </button>\n          <button\n            type=\"button\"\n            class=\"challengeCommitBtn\"\n            onclick=\"selectCommitment(this, 'NO')\"\n          >\n            NO\n          </button>\n        </div>\n\n        <input type=\"hidden\" id=\"commitment\" name=\"commitment\" required />\n\n        <button type=\"submit\" class=\"challengeSubmitBtn\">\n          Join the Waitlist!\n        </button>\n      </form>\n\n      <!-- Updated Popup message -->\n      <div id=\"popupMessage\" class=\"popupMessage\">\n        <div class=\"popupContent\">\n          <div class=\"popupIcon\">✓</div>\n          <h2 class=\"popupTitle\">You're on the Waitlist!</h2>\n          <p class=\"popupText\">\n            Thank you for joining the waitlist for the\n            <strong>90-Day Kill Your Distraction Challenge</strong>.<br /><br />\n            We'll contact you with updates and early access information as we\n            approach the launch date.<br />\n            <br />\n            Redirecting to the homepage in\n            <span id=\"redirectSeconds\" class=\"redirectCountdown\">7</span>\n            seconds...\n          </p>\n        </div>\n      </div>\n    </div>\n\n    <style>\n      @font-face {\n        font-family: \"CooperBoldBT\";\n        src: url(\"https://cdn.shopify.com/s/files/1/1494/6308/files/cooper-bold-bt-2.ttf.ttf\")\n          format(\"truetype\");\n        font-weight: bold;\n        font-style: normal;\n      }\n\n      .challengeFormWrapper {\n        max-width: 900px;\n        margin: 0 auto;\n        padding: 40px 20px;\n        background-color: #fff;\n      }\n\n      .challengeFormTitle {\n        color: #2563eb;\n        font-family: \"CooperBoldBT\", sans-serif;\n        font-size: 2rem;\n        font-weight: 700;\n        margin-bottom: 8px;\n      }\n\n      .challengeFormSubtitle {\n        color: #2563eb;\n        margin-bottom: 32px;\n        font-size: 1.05rem;\n      }\n\n      .challengeFormSectionTitle {\n        color: #2563eb;\n        font-family: \"CooperBoldBT\", sans-serif;\n        font-size: 1.25rem;\n        font-weight: 700;\n        margin: 32px 0 16px 0;\n      }\n\n      .challengeFormLabel {\n        display: block;\n        font-weight: 600;\n        color: #2563eb;\n        margin-bottom: 8px;\n        font-size: 1rem;\n      }\n\n      .challengeFormInput {\n        width: 100%;\n        padding: 12px 0px;\n        border: none;\n        border-bottom: 1px solid #2563eb66;\n        font-size: 1rem;\n        margin-bottom: 20px;\n        box-sizing: border-box;\n        color: #2563eb;\n      }\n\n      .challengeFormInput::placeholder {\n        color: #2563eb99;\n        font-size: 0.95rem;\n      }\n\n      /* Removed focus outline as requested */\n      .challengeFormInput:focus {\n        outline: none;\n        border-bottom: 1px solid #2563eb;\n      }\n\n      .challengeFormParagraph {\n        font-weight: bold;\n        color: #2563eb;\n        font-size: 1rem;\n      }\n\n      .challengeRangeWrapper {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 10px;\n        color: #2563eb;\n        font-size: 1rem;\n      }\n\n      .challengeRangeInput {\n        flex: 1;\n        accent-color: #2563eb;\n      }\n\n      .challengeCommitWrapper {\n        display: flex;\n        gap: 16px;\n        margin-bottom: 24px;\n      }\n\n      .challengeCommitBtn {\n        flex: 1;\n        border: 1px solid #2563eb;\n        border-radius: 8px;\n        padding: 12px 0;\n        background-color: #ffffff;\n        color: #2563eb;\n        font-weight: 600;\n        cursor: pointer;\n        transition: all 0.2s ease;\n      }\n\n      .challengeCommitBtn.active {\n        background-color: #2563eb;\n        color: #ffffff;\n      }\n\n      .challengeSubmitBtn {\n        width: 100%;\n        background-color: #2563eb;\n        color: #ffffff;\n        border: none;\n        border-radius: 8px;\n        padding: 14px;\n        font-size: 1.25rem;\n        font-weight: 600;\n        cursor: pointer;\n        transition: background-color 0.3s ease;\n      }\n\n      .challengeSubmitBtn:hover {\n        background-color: #1e40af;\n      }\n\n      /* Updated popup styling - larger and more prominent */\n      .popupMessage {\n        position: fixed;\n        top: 0;\n        left: 0;\n        right: 0;\n        bottom: 0;\n        background: rgba(244, 248, 255, 0.95); /* More opaque blue background */\n        display: none;\n        align-items: center;\n        justify-content: center;\n        z-index: 9999;\n        padding: 20px;\n      }\n\n      .popupContent {\n        background: white;\n        padding: 50px 40px;\n        border-radius: 20px;\n        text-align: center;\n        max-width: 700px; /* Increased width */\n        width: 90%;\n        color: #2563eb;\n        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);\n        animation: fadeInScale 0.4s ease-out;\n        position: relative;\n      }\n\n      .popupIcon {\n        font-size: 4rem;\n        color: #10b981;\n        margin-bottom: 20px;\n        line-height: 1;\n      }\n\n      .popupTitle {\n        font-family: \"CooperBoldBT\", sans-serif;\n        margin-bottom: 20px;\n        font-size: 2.2rem; /* Increased text size */\n        color: #2563eb;\n      }\n\n      .popupText {\n        font-size: 1.3rem; /* Increased text size */\n        line-height: 1.6;\n        margin-bottom: 30px;\n        color: #1e293b;\n      }\n\n      .redirectCountdown {\n        font-weight: bold;\n        color: #2563eb;\n        font-size: 1.4rem;\n      }\n\n      .popupProgressBar {\n        width: 100%;\n        height: 8px;\n        background-color: #e2e8f0;\n        border-radius: 4px;\n        margin: 25px 0;\n        overflow: hidden;\n      }\n\n      .popupProgressFill {\n        height: 100%;\n        width: 100%;\n        background-color: #2563eb;\n        border-radius: 4px;\n        animation: progressCountdown 7s linear forwards;\n      }\n\n      .popupCloseBtn {\n        background-color: #2563eb;\n        color: white;\n        border: none;\n        border-radius: 8px;\n        padding: 12px 30px;\n        font-size: 1.1rem;\n        font-weight: 600;\n        cursor: pointer;\n        transition: background-color 0.3s ease;\n      }\n\n      .popupCloseBtn:hover {\n        background-color: #1e40af;\n      }\n\n      @keyframes fadeInScale {\n        from {\n          opacity: 0;\n          transform: scale(0.8);\n        }\n        to {\n          opacity: 1;\n          transform: scale(1);\n        }\n      }\n\n      @keyframes progressCountdown {\n        from {\n          width: 100%;\n        }\n        to {\n          width: 0%;\n        }\n      }\n\n      @media (max-width: 768px) {\n        .challengeFormTitle {\n          font-size: 1.6rem;\n        }\n        .challengeFormSectionTitle {\n          font-size: 1.1rem;\n        }\n        .challengeFormWrapper {\n          padding: 24px 16px;\n        }\n        .challengeFormLabel,\n        .challengeFormParagraph,\n        .challengeFormInput {\n          font-size: 0.95rem;\n        }\n\n        /* Responsive popup adjustments */\n        .popupContent {\n          padding: 40px 25px;\n          max-width: 90%;\n          border-radius: 16px;\n        }\n\n        .popupIcon {\n          font-size: 3rem;\n        }\n\n        .popupTitle {\n          font-size: 1.8rem;\n        }\n\n        .popupText {\n          font-size: 1.1rem;\n        }\n\n        .redirectCountdown {\n          font-size: 1.2rem;\n        }\n      }\n\n      @media (max-width: 480px) {\n        .popupContent {\n          padding: 30px 20px;\n        }\n\n        .popupIcon {\n          font-size: 2.5rem;\n        }\n\n        .popupTitle {\n          font-size: 1.6rem;\n        }\n\n        .popupText {\n          font-size: 1rem;\n        }\n\n        .popupCloseBtn {\n          padding: 10px 25px;\n          font-size: 1rem;\n        }\n      }\n.challengeFormInput:focus {\n  outline: none !important;\n  border: none !important;\n  border-bottom: 1px solid #2563eb !important;\n  box-shadow: none !important;\n}\n    </style>\n\n    <script>\n      function selectCommitment(button, value) {\n        const buttons = document.querySelectorAll(\".challengeCommitBtn\");\n        buttons.forEach((btn) => btn.classList.remove(\"active\"));\n        button.classList.add(\"active\");\n        document.getElementById(\"commitment\").value = value;\n      }\n\n      function closePopup() {\n        const popup = document.getElementById(\"popupMessage\");\n        popup.style.display = \"none\";\n        window.location.href = \"https://jaffary.com/\";\n      }\n\n      document.addEventListener(\"DOMContentLoaded\", () => {\n        const form = document.getElementById(\"challengeForm\");\n        const popup = document.getElementById(\"popupMessage\");\n        const redirectSeconds = document.getElementById(\"redirectSeconds\");\n\n        const GOOGLE_SCRIPT_URL =\n          \"https://script.google.com/macros/s/AKfycbxx60J5R9A8Cf3ehJbdCTCGvMLIHuZ4PjoY1lDPgWVLDsZh5ayixbgHjtsS8R4rK9te/exec\";\n\n        form.addEventListener(\"submit\", async (e) => {\n          e.preventDefault();\n\n          const formData = new FormData(form);\n\n          try {\n            const res = await fetch(GOOGLE_SCRIPT_URL, {\n              method: \"POST\",\n              body: formData,\n            });\n\n            if (res.ok) {\n              popup.style.display = \"flex\";\n              form.reset();\n              document\n                .querySelectorAll(\".challengeCommitBtn\")\n                .forEach((b) => b.classList.remove(\"active\"));\n              document.getElementById(\"scaleValueDisplay\").textContent = \"0\";\n\n              let seconds = 7; // Changed to 7 seconds\n              const countdown = setInterval(() => {\n                seconds--;\n                redirectSeconds.textContent = seconds;\n                if (seconds === 0) {\n                  clearInterval(countdown);\n                  window.location.href = \"https://jaffary.com/\";\n                }\n              }, 1000);\n            } else {\n              alert(\"Submission failed. Please try again later.\");\n            }\n          } catch (err) {\n            alert(\"Network error. Please try again later.\");\n            console.error(err);\n          }\n        });\n      });\n    </script>\n  </body>",
        "color_scheme": "primary"
      }
