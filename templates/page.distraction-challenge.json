        "custom_liquid": "<body>\n    <div class=\"challengeFormWrapper\">\n      <h1 class=\"challengeFormTitle\">90-Day Kill Your Distraction Challenge</h1>\n      <p class=\"challengeFormSubtitle\">\n        Join the waitlist and start your transformation.\n      </p>\n\n      <h3 class=\"challengeFormSectionTitle\">Your Information</h3>\n      <form id=\"challengeForm\">\n        <label for=\"firstName\" class=\"challengeFormLabel\">First Name*</label>\n        <input\n          type=\"text\"\n          id=\"firstName\"\n          name=\"firstName\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your Name\"\n        />\n\n        <label for=\"lastName\" class=\"challengeFormLabel\">Last Name*</label>\n        <input\n          type=\"text\"\n          id=\"lastName\"\n          name=\"lastName\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Last name\"\n        />\n\n        <label for=\"email\" class=\"challengeFormLabel\">Email Address*</label>\n        <input\n          type=\"email\"\n          id=\"email\"\n          name=\"email\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your email address\"\n        />\n\n        <label for=\"phone\" class=\"challengeFormLabel\">Phone Number*</label>\n        <input\n          type=\"tel\"\n          id=\"phone\"\n          name=\"phone\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Your phone number\"\n        />\n\n        <h3 class=\"challengeFormSectionTitle\">Your Distraction Challenge</h3>\n\n        <label for=\"distraction\" class=\"challengeFormLabel\"\n          >What is your biggest distraction right now?*</label\n        >\n        <input\n          type=\"text\"\n          id=\"distraction\"\n          name=\"distraction\"\n          required\n          class=\"challengeFormInput\"\n          placeholder=\"Social media, smartphone, TV, etc.\"\n        />\n\n        <p>\n          On a scale of 1 to 100, how distracted do you feel on a daily basis?*\n        </p>\n        <div class=\"challengeRangeWrapper\">\n          <span>0</span>\n          <input\n            type=\"range\"\n            id=\"scale\"\n            name=\"scale\"\n            min=\"0\"\n            max=\"100\"\n            value=\"0\"\n            class=\"challengeRangeInput\"\n          />\n          <span>100</span>\n        </div>\n\n        <label class=\"challengeFormLabel\" style=\"margin: 24px 0px 12px\"\n          >Are you ready to commit to 90 days of focus and discipline?*</label\n        >\n        <div class=\"challengeCommitWrapper\">\n          <button\n            type=\"button\"\n            class=\"challengeCommitBtn\"\n            onclick=\"selectCommitment(this, 'YES')\"\n          >\n            YES\n          </button>\n          <button\n            type=\"button\"\n            class=\"challengeCommitBtn\"\n            onclick=\"selectCommitment(this, 'NO')\"\n          >\n            NO\n          </button>\n        </div>\n\n        <input type=\"hidden\" id=\"commitment\" name=\"commitment\" required />\n\n        <button type=\"submit\" class=\"challengeSubmitBtn\">\n          Join the Waitlist!\n        </button>\n      </form>\n\n      <div\n        id=\"confirmationMessage\"\n        class=\"challengeConfirmMsg\"\n        role=\"alert\"\n      ></div>\n    </div>\n\n    <!-- Load Cooper Bold BT font -->\n    <style>\n      @font-face {\n        font-family: \"CooperBoldBT\";\n        src: url(\"https://cdn.shopify.com/s/files/1/1494/6308/files/cooper-bold-bt-2.ttf.ttf\")\n          format(\"truetype\");\n        font-weight: bold;\n        font-style: normal;\n      }\n    </style>\n\n    <style>\n      /* === FORM CONTAINER === */\n      .challengeFormWrapper {\n        max-width: 900px;\n        margin: 0 auto;\n        padding: 40px 20px;\n        background-color: #fff;\n      }\n\n      /* === HEADINGS === */\n      .challengeFormTitle {\n        color: #2563eb;\n        font-family: \"CooperBoldBT\", sans-serif;\n        font-size: 2rem;\n        font-weight: 700;\n        margin-bottom: 8px;\n      }\n\n      .challengeFormSubtitle {\n        color: #404040;\n        margin-bottom: 32px;\n      }\n\n      .challengeFormSectionTitle {\n        color: #2563eb;\n        font-family: \"CooperBoldBT\", sans-serif;\n        font-size: 1.25rem;\n        font-weight: 700;\n        margin: 32px 0 16px 0;\n      }\n\n      /* === LABELS & INPUTS === */\n      .challengeFormLabel {\n        display: block;\n        font-weight: 600;\n        color: #000;\n        margin-bottom: 8px;\n      }\n\n      .challengeFormInput {\n        width: 100%;\n        padding: 12px 0px;\n        border: none;\n        border-bottom: 1px solid #d1d5db;\n        font-size: 0.9rem;\n        margin-bottom: 20px;\n        box-sizing: border-box;\n      }\n\n      .challengeFormInput:focus {\n        outline: none;\n        box-shadow: 0 0 0 2px #2563eb33;\n      }\n\n      /* === RANGE === */\n      .challengeRangeWrapper {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 10px;\n      }\n\n      .challengeRangeInput {\n        flex: 1;\n        accent-color: #2563eb;\n      }\n\n      /* === YES/NO BUTTONS === */\n      .challengeCommitWrapper {\n        display: flex;\n        gap: 16px;\n        margin-bottom: 24px;\n      }\n\n      .challengeCommitBtn {\n        flex: 1;\n        border: 1px solid #2563eb;\n        border-radius: 8px;\n        padding: 12px 0;\n        background-color: #ffffff;\n        color: #2563eb;\n        font-weight: 600;\n        cursor: pointer;\n        transition: all 0.2s ease;\n      }\n\n      .challengeCommitBtn.active {\n        background-color: #2563eb;\n        color: #ffffff;\n      }\n\n      /* === SUBMIT BUTTON === */\n      .challengeSubmitBtn {\n        width: 100%;\n        background-color: #2563eb;\n        color: #ffffff;\n        border: none;\n        border-radius: 8px;\n        padding: 14px;\n        font-size: 1.25rem;\n        font-weight: 600;\n        cursor: pointer;\n        transition: background-color 0.3s ease;\n      }\n\n      .challengeSubmitBtn:hover {\n        background-color: #1e40af;\n      }\n\n      /* === CONFIRMATION MESSAGE === */\n      .challengeConfirmMsg {\n        margin-top: 20px;\n        padding: 12px;\n        border-radius: 8px;\n        font-size: 0.95rem;\n        text-align: center;\n        display: none;\n      }\n\n      .challengeConfirmSuccess {\n        background-color: #dcfce7;\n        color: #166534;\n        border: 1px solid #16a34a;\n      }\n\n      .challengeConfirmError {\n        background-color: #fee2e2;\n        color: #b91c1c;\n        border: 1px solid #b91c1c;\n      }\n\n      /* === RESPONSIVE === */\n      @media (max-width: 480px) {\n        .challengeFormTitle {\n          font-size: 1.6rem;\n        }\n        .challengeFormSectionTitle {\n          font-size: 1.1rem;\n        }\n        .challengeFormWrapper {\n          padding: 24px 16px;\n        }\n      }\n    </style>\n\n    <script>\n      // YES/NO Button selection\n      function selectCommitment(button, value) {\n        const buttons = document.querySelectorAll(\".challengeCommitBtn\");\n        buttons.forEach((btn) => btn.classList.remove(\"active\"));\n        button.classList.add(\"active\");\n        document.getElementById(\"commitment\").value = value;\n      }\n\n      // Form submission\n      document.addEventListener(\"DOMContentLoaded\", () => {\n        const form = document.getElementById(\"challengeForm\");\n        const message = document.getElementById(\"confirmationMessage\");\n\n        const GOOGLE_SCRIPT_URL =\n          \"https://script.google.com/macros/s/AKfycbzbR-9bx0mrDQI1guoISJ1XqYdqOQZZbsGJWApyOkyB9-aHbyQ7mQAjCeWuMGbgDOhX/exec\";\n\n        form.addEventListener(\"submit\", async (e) => {\n          e.preventDefault();\n          message.style.display = \"block\";\n          message.textContent = \"Submitting... please wait.\";\n          message.className = \"challengeConfirmMsg\";\n\n          const formData = new FormData(form);\n\n          try {\n            const res = await fetch(GOOGLE_SCRIPT_URL, {\n              method: \"POST\",\n              body: formData,\n            });\n\n            if (res.ok) {\n              message.textContent =\n                \"✅ Success! You've been added to the waitlist.\";\n              message.classList.add(\"challengeConfirmSuccess\");\n              form.reset();\n              document\n                .querySelectorAll(\".challengeCommitBtn\")\n                .forEach((b) => b.classList.remove(\"active\"));\n            } else {\n              throw new Error(\"Server error\");\n            }\n          } catch (err) {\n            message.textContent =\n              \"❌ Submission failed. Please try again later.\";\n            message.classList.add(\"challengeConfirmError\");\n            console.error(err);\n          }\n        });\n      });\n    </script>\n  </body>",
        "color_scheme": "primary"
      }
