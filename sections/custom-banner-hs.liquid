{% comment %}
  Hero Banner Slider — v3
  Fix: Swiper loaded only once across multiple section instances
{% endcomment %}

<style>
  /* =============================================
     Section Container
  ============================================= */
  .section-container--{{ section.id }} {
    margin-top: {{ section.settings.margin_top | append: 'px' }};
    margin-bottom: {{ section.settings.margin_bottom | append: 'px' }};
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    position: relative;
  }
  @media screen and (max-width: 768px) {
    .section-container--{{ section.id }} {
      margin-top: {{ section.settings.margin_top_mobile | append: 'px' }};
      margin-bottom: {{ section.settings.margin_bottom_mobile | append: 'px' }};
    }
  }

  /* =============================================
     Slide Base
  ============================================= */
  .hero-slide--{{ section.id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  /* =============================================
     Background Container & Media — Base Rules
  ============================================= */
  .hero-slide__bg--{{ section.id }} {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
  }
  .hero-slide__bg--{{ section.id }} img,
  .hero-slide__bg--{{ section.id }} video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* =============================================
     Height Modes
  ============================================= */
  {%- assign hdr = section.settings.header_height | default: 0 -%}

  {% if section.settings.height_type == 'viewport' %}
    .hero-slide--{{ section.id }} {
      height: calc(100vh - {{ hdr }}px);
    }

  {% elsif section.settings.height_type == 'fixed' %}
    .hero-slide--{{ section.id }} {
      height: {{ section.settings.fixed_height }}px;
    }
    @media screen and (max-width: 768px) {
      .hero-slide--{{ section.id }} {
        height: {{ section.settings.fixed_height_mobile }}px;
      }
    }

  {% else %}
    /* Adaptive */
    .hero-slide--{{ section.id }} {
      height: auto;
      max-height: calc(100vh - {{ hdr }}px);
    }
    .hero-slide--{{ section.id }} .hero-slide__bg--{{ section.id }} {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
    }
    .hero-slide--{{ section.id }} .hero-slide__bg--{{ section.id }} img,
    .hero-slide--{{ section.id }} .hero-slide__bg--{{ section.id }} video {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
      max-height: calc(100vh - {{ hdr }}px);
      object-fit: cover;
      display: block;
    }
  {% endif %}

  /* =============================================
     Mobile / Desktop Media Visibility
  ============================================= */
  .hero-slide--{{ section.id }} .hero-media--mobile {
    display: none !important;
  }
  @media screen and (max-width: 768px) {
    .hero-slide--{{ section.id }} .hero-media--mobile {
      display: block !important;
    }
    .hero-slide--{{ section.id }}.has-mobile-media .hero-media--desktop {
      display: none !important;
    }
  }

  /* =============================================
     Overlay
  ============================================= */
  .hero-slide__overlay--{{ section.id }} {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.32);
    z-index: 1;
    pointer-events: none;
  }

  /* =============================================
     Content Layer
  ============================================= */
  .hero-slide__content--{{ section.id }} {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    padding: 48px 60px;
    box-sizing: border-box;
  }
  @media screen and (max-width: 768px) {
    .hero-slide__content--{{ section.id }} {
      padding: 28px 20px;
    }
  }

  .hero-slide__inner--{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 640px;
  }

  /* =============================================
     Content Position Classes
  ============================================= */
  .hbs-pos-top_left--{{ section.id }}      { align-items: flex-start; justify-content: flex-start; }
  .hbs-pos-top_center--{{ section.id }}    { align-items: flex-start; justify-content: center; }
  .hbs-pos-top_right--{{ section.id }}     { align-items: flex-start; justify-content: flex-end; }
  .hbs-pos-middle_left--{{ section.id }}   { align-items: center;     justify-content: flex-start; }
  .hbs-pos-middle_center--{{ section.id }} { align-items: center;     justify-content: center; }
  .hbs-pos-middle_right--{{ section.id }}  { align-items: center;     justify-content: flex-end; }
  .hbs-pos-bottom_left--{{ section.id }}   { align-items: flex-end;   justify-content: flex-start; }
  .hbs-pos-bottom_center--{{ section.id }} { align-items: flex-end;   justify-content: center; }
  .hbs-pos-bottom_right--{{ section.id }}  { align-items: flex-end;   justify-content: flex-end; }

  .hbs-pos-top_center--{{ section.id }}    .hero-slide__inner--{{ section.id }},
  .hbs-pos-middle_center--{{ section.id }} .hero-slide__inner--{{ section.id }},
  .hbs-pos-bottom_center--{{ section.id }} .hero-slide__inner--{{ section.id }} {
    align-items: center;
    text-align: center;
  }
  .hbs-pos-top_right--{{ section.id }}    .hero-slide__inner--{{ section.id }},
  .hbs-pos-middle_right--{{ section.id }} .hero-slide__inner--{{ section.id }},
  .hbs-pos-bottom_right--{{ section.id }} .hero-slide__inner--{{ section.id }} {
    align-items: flex-end;
    text-align: right;
  }

  /* =============================================
     Typography
  ============================================= */
  .hero-slide__title--{{ section.id }} {
    font-size: clamp(2rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero-slide__subtitle--{{ section.id }} {
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    line-height: 1.6;
    opacity: 0.88;
    margin: 0;
  }
  .hero-slide__subtitle--{{ section.id }} p { margin: 0; }

  /* =============================================
     Button
  ============================================= */
  .hero-slide__btn--{{ section.id }} {
    display: inline-block;
    padding: 13px 36px;
    border-width: 1.5px;
    border-style: solid;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 4px;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease;
  }

  /* =============================================
     Countdown Timer
  ============================================= */
  .hero-countdown-wrap--{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .hero-countdown__launching--{{ section.id }} {
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
    margin: 0;
  }
  .hero-countdown--{{ section.id }} {
    display: flex;
    align-items: center;
  }
  .hero-countdown__unit--{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 52px;
  }
  .hero-countdown__num--{{ section.id }} {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .hero-countdown__unit-label--{{ section.id }} {
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.65;
    margin-top: 4px;
  }
  .hero-countdown__sep--{{ section.id }} {
    font-size: 1.6rem;
    font-weight: 300;
    opacity: 0.4;
    padding: 0 4px;
    align-self: flex-start;
    margin-top: 4px;
  }

  /* =============================================
     Swiper Navigation
  ============================================= */
  .hero-slider--{{ section.id }} .swiper-button-next,
  .hero-slider--{{ section.id }} .swiper-button-prev {
    color: rgba(255, 255, 255, 0.85);
    --swiper-navigation-size: 28px;
  }
  .hero-slider--{{ section.id }} .swiper-button-next:hover,
  .hero-slider--{{ section.id }} .swiper-button-prev:hover {
    color: #fff;
  }
  .hero-slider--{{ section.id }} .swiper-pagination-bullet {
    background: rgba(255, 255, 255, 0.55);
    opacity: 1;
  }
  .hero-slider--{{ section.id }} .swiper-pagination-bullet-active {
    background: #fff;
    transform: scale(1.3);
  }
</style>

<section class="section-container--{{ section.id }}">
  <div
    class="hero-slider--{{ section.id }} swiper"
    id="hero-slider-{{ section.id }}"
    data-slide-count="{{ section.blocks.size }}"
    data-autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
    data-autoheight="{% if section.settings.height_type == 'adaptive' %}true{% else %}false{% endif %}"
  >
    <div class="swiper-wrapper">

      {% for block in section.blocks %}

        {%- liquid
          assign has_mobile_media = false
          if block.settings.mobile_media_type == 'image' and block.settings.mobile_image != blank
            assign has_mobile_media = true
          endif
          if block.settings.mobile_media_type == 'video' and block.settings.mobile_video != blank
            assign has_mobile_media = true
          endif

          assign txt_color = block.settings.text_color
          if txt_color == blank
            assign txt_color = '#ffffff'
          endif

          assign btn_href = block.settings.button_url
          if btn_href == blank
            assign btn_href = '#'
          endif
        -%}

        <div
          class="swiper-slide hero-slide--{{ section.id }}{% if has_mobile_media %} has-mobile-media{% endif %}"
          {{ block.shopify_attributes }}
        >

          <!-- Background Media -->
          <div class="hero-slide__bg--{{ section.id }}">

            {% if block.settings.desktop_media_type == 'video' and block.settings.desktop_video != blank %}
              <video class="hero-media--desktop" autoplay muted loop playsinline aria-hidden="true">
                <source src="{{ block.settings.desktop_video }}" type="video/mp4">
              </video>
            {% elsif block.settings.desktop_image != blank %}
              {{
                block.settings.desktop_image
                | image_url: width: 2000
                | image_tag:
                  class: 'hero-media--desktop',
                  loading: 'lazy',
                  widths: '375, 550, 750, 1100, 1500, 1780, 2000',
                  sizes: '100vw',
                  alt: block.settings.desktop_image.alt | default: block.settings.title
              }}
            {% endif %}

            {% if block.settings.mobile_media_type == 'video' and block.settings.mobile_video != blank %}
              <video class="hero-media--mobile" autoplay muted loop playsinline aria-hidden="true">
                <source src="{{ block.settings.mobile_video }}" type="video/mp4">
              </video>
            {% elsif block.settings.mobile_media_type == 'image' and block.settings.mobile_image != blank %}
              {{
                block.settings.mobile_image
                | image_url: width: 800
                | image_tag:
                  class: 'hero-media--mobile',
                  loading: 'lazy',
                  widths: '375, 550, 750, 800',
                  sizes: '100vw',
                  alt: block.settings.mobile_image.alt | default: block.settings.title
              }}
            {% endif %}

          </div>

          <!-- Overlay -->
          <div class="hero-slide__overlay--{{ section.id }}"></div>

          <!-- Content -->
          <div class="hero-slide__content--{{ section.id }} hbs-pos-{{ block.settings.content_position }}--{{ section.id }}">
            <div
              class="hero-slide__inner--{{ section.id }}"
              style="color: {{ txt_color }};"
            >

              {% if block.settings.title != blank %}
                <h2 class="hero-slide__title--{{ section.id }}">{{ block.settings.title }}</h2>
              {% endif %}

              {% if block.settings.subtitle != blank %}
                <div class="hero-slide__subtitle--{{ section.id }}">{{ block.settings.subtitle }}</div>
              {% endif %}

              {% if block.settings.countdown_date != blank %}
                <div class="hero-countdown-wrap--{{ section.id }}">
                  <p class="hero-countdown__launching--{{ section.id }}">Launching in:</p>
                  <div class="hero-countdown--{{ section.id }}" data-countdown="{{ block.settings.countdown_date }}">
                    <div class="hero-countdown__unit--{{ section.id }}">
                      <span class="hero-countdown__num--{{ section.id }} js-cd-days">0</span>
                      <span class="hero-countdown__unit-label--{{ section.id }}">Days</span>
                    </div>
                    <span class="hero-countdown__sep--{{ section.id }}">|</span>
                    <div class="hero-countdown__unit--{{ section.id }}">
                      <span class="hero-countdown__num--{{ section.id }} js-cd-hours">00</span>
                      <span class="hero-countdown__unit-label--{{ section.id }}">Hours</span>
                    </div>
                    <span class="hero-countdown__sep--{{ section.id }}">|</span>
                    <div class="hero-countdown__unit--{{ section.id }}">
                      <span class="hero-countdown__num--{{ section.id }} js-cd-minutes">00</span>
                      <span class="hero-countdown__unit-label--{{ section.id }}">Minutes</span>
                    </div>
                    <span class="hero-countdown__sep--{{ section.id }}">|</span>
                    <div class="hero-countdown__unit--{{ section.id }}">
                      <span class="hero-countdown__num--{{ section.id }} js-cd-seconds">00</span>
                      <span class="hero-countdown__unit-label--{{ section.id }}">Seconds</span>
                    </div>
                  </div>
                </div>
              {% endif %}

              {% if block.settings.button_title != blank %}
                <a
                  href="{{ btn_href }}"
                  class="hero-slide__btn--{{ section.id }}"
                  style="color: {{ txt_color }}; border-color: {{ txt_color }};"
                >{{ block.settings.button_title }}</a>
              {% endif %}

            </div>
          </div>

        </div>
      {% endfor %}

    </div>

    {% if section.blocks.size > 1 %}
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
      <div class="swiper-pagination"></div>
    {% endif %}

  </div>
</section>

<script>
(function () {
  'use strict';

  var SWIPER_CSS = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css';
  var SWIPER_JS  = 'https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js';

  /* ── Init this specific section slider ─────────── */
  function initSlider() {
    var el = document.getElementById('hero-slider-{{ section.id }}');
    if (!el || el.dataset.swiperInitialized) return;
    el.dataset.swiperInitialized = 'true';

    var slideCount    = parseInt(el.getAttribute('data-slide-count'), 10);
    var autoplayDelay = parseInt(el.getAttribute('data-autoplay-delay'), 10);
    var autoHeight    = el.getAttribute('data-autoheight') === 'true';

    if (slideCount > 1) {
      new Swiper(el, {
        loop: true,
        speed: 700,
        autoplay: {
          delay: autoplayDelay,
          disableOnInteraction: false,
          pauseOnMouseEnter: true
        },
        autoHeight: autoHeight,
        pagination: {
          el: el.querySelector('.swiper-pagination'),
          clickable: true
        },
        navigation: {
          nextEl: el.querySelector('.swiper-button-next'),
          prevEl: el.querySelector('.swiper-button-prev')
        }
      });
    }

    /* ── Countdown Timers ───────────────────────── */
    el.querySelectorAll('[data-countdown]').forEach(function (timerEl) {
      var target = new Date(timerEl.getAttribute('data-countdown')).getTime();
      function pad(n) { return String(n).padStart(2, '0'); }
      function tick() {
        var diff = target - Date.now();
        if (isNaN(diff) || diff <= 0) {
          timerEl.innerHTML = '<span style="font-size:1rem;letter-spacing:.12em;opacity:.8">Launched!</span>';
          return;
        }
        timerEl.querySelector('.js-cd-days').textContent    = Math.floor(diff / 86400000);
        timerEl.querySelector('.js-cd-hours').textContent   = pad(Math.floor((diff % 86400000) / 3600000));
        timerEl.querySelector('.js-cd-minutes').textContent = pad(Math.floor((diff % 3600000) / 60000));
        timerEl.querySelector('.js-cd-seconds').textContent = pad(Math.floor((diff % 60000) / 1000));
      }
      tick();
      setInterval(tick, 1000);
    });
  }

  /* ── Load Swiper once, queue all section inits ── */
  window.__swiperQueue = window.__swiperQueue || [];
  window.__swiperQueue.push(initSlider);

  if (window.Swiper) {
    /* Swiper already loaded — run immediately */
    initSlider();
  } else if (!window.__swiperLoading) {
    /* First section to request Swiper — load it now */
    window.__swiperLoading = true;

    var link = document.createElement('link');
    link.rel  = 'stylesheet';
    link.href = SWIPER_CSS;
    document.head.appendChild(link);

    var script  = document.createElement('script');
    script.src  = SWIPER_JS;
    script.onload = function () {
      /* Run every queued init (covers all section instances on the page) */
      (window.__swiperQueue || []).forEach(function (fn) { fn(); });
      window.__swiperQueue = [];
    };
    document.head.appendChild(script);
  }
  /* else: Swiper is already being fetched by another section instance.
     Our initSlider is already in __swiperQueue and will be called
     when the script.onload fires above. Nothing else needed. */

})();
</script>

{% schema %}
{
  "name": "Hero Banner Slider",
  "settings": [
    {
      "type": "header",
      "content": "Slide Height"
    },
    {
      "type": "select",
      "id": "height_type",
      "label": "Height Mode",
      "options": [
        { "value": "adaptive", "label": "Adaptive (content height)" },
        { "value": "viewport", "label": "Viewport (full screen)" },
        { "value": "fixed",    "label": "Fixed pixel" }
      ],
      "default": "viewport"
    },
    {
      "type": "range",
      "id": "header_height",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Header Height Offset",
      "default": 0,
      "info": "Enter your theme header height. Viewport and Adaptive modes subtract this so the slider never hides behind the header."
    },
    {
      "type": "range",
      "id": "fixed_height",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Fixed Height – Desktop",
      "default": 640,
      "info": "Only applies when Height Mode is Fixed."
    },
    {
      "type": "range",
      "id": "fixed_height_mobile",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Fixed Height – Mobile",
      "default": 420,
      "info": "Only applies when Height Mode is Fixed."
    },
    {
      "type": "header",
      "content": "Slider Options"
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 2,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Delay",
      "default": 5,
      "info": "Seconds per slide. Only active when 2 or more slides are added."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#000000",
      "info": "Visible while media is loading."
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Spacing"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Top (Mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom (Mobile)",
      "default": 0
    }
  ],
  "blocks": [
    {
      "name": "Slide",
      "type": "slide",
      "settings": [
        {
          "type": "header",
          "content": "Desktop Media"
        },
        {
          "type": "select",
          "id": "desktop_media_type",
          "label": "Desktop: Show",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Image"
        },
        {
          "type": "text",
          "id": "desktop_video",
          "label": "Desktop Video URL (.mp4)",
          "info": "Upload to Shopify Files and paste the URL. Active when Desktop: Show is set to Video."
        },
        {
          "type": "header",
          "content": "Mobile Media"
        },
        {
          "type": "select",
          "id": "mobile_media_type",
          "label": "Mobile: Show",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Image",
          "info": "Optional. Leave blank to use the Desktop Image on mobile too."
        },
        {
          "type": "text",
          "id": "mobile_video",
          "label": "Mobile Video URL (.mp4)",
          "info": "Optional. Leave blank to use the Desktop Video on mobile too."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "Content Position",
          "options": [
            { "value": "top_left",      "label": "Top Left" },
            { "value": "top_center",    "label": "Top Center" },
            { "value": "top_right",     "label": "Top Right" },
            { "value": "middle_left",   "label": "Middle Left" },
            { "value": "middle_center", "label": "Middle Center" },
            { "value": "middle_right",  "label": "Middle Right" },
            { "value": "bottom_left",   "label": "Bottom Left" },
            { "value": "bottom_center", "label": "Bottom Center" },
            { "value": "bottom_right",  "label": "Bottom Right" }
          ],
          "default": "middle_center"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text & Button Color",
          "default": "#ffffff",
          "info": "Applies to title, subtitle, button text and button border."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "button_title",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Countdown Timer"
        },
        {
          "type": "text",
          "id": "countdown_date",
          "label": "Countdown Target Date & Time",
          "info": "Format: YYYY-MM-DDTHH:MM:SS — e.g. 2025-12-31T23:59:59. Leave blank to hide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner Slider",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}