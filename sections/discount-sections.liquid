      .circle-{{ sid }} .circle-locked-row { flex-direction: column; gap: 14px; }
      .circle-{{ sid }} .circle-locked-right { align-items: flex-start; width: 100%; }
      .circle-{{ sid }} .circle-notify-inline { width: 100%; }
      .circle-{{ sid }} .circle-notify-inline input { flex: 1; width: auto; }
      .circle-{{ sid }} .circle-selected-preview { flex-wrap: wrap; }
    }
</style>

<script>
(() => {
  const root = document.querySelector('[data-circle-section="{{ sid }}"]');
  if (!root) return;

  const sid         = '{{ sid }}';
  const STORAGE_KEY = 'circle_access_' + sid;
  const ACCESS_DURATION = 24 * 60 * 60 * 1000;

  const gateEl    = document.getElementById('circle-code-gate-' + sid);
  const offerEl   = document.getElementById('circle-offer-content-' + sid);
  const codeInput = document.getElementById('circle-code-input-' + sid);
  const submitBtn = document.getElementById('circle-code-submit-' + sid);
  const errorEl   = document.getElementById('circle-code-error-' + sid);

  const rawCodes   = (root.dataset.accessCodes || '').trim();
  const validCodes = rawCodes.length
    ? rawCodes.split(',').map(c => c.trim().toUpperCase()).filter(Boolean)
    : [];

  // ── localStorage check ──
  function isVerified() {
    try {
      const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
      if (!saved || !saved.code || !saved.expires || !saved.codeList) return false;
      if (Date.now() > saved.expires) { localStorage.removeItem(STORAGE_KEY); return false; }
      if (saved.codeList !== rawCodes) { localStorage.removeItem(STORAGE_KEY); return false; }
      if (!validCodes.includes(saved.code)) { localStorage.removeItem(STORAGE_KEY); return false; }
      return true;
    } catch (e) {
      localStorage.removeItem(STORAGE_KEY);
      return false;
    }
  }

  function grantAccess(code) {
    if (code) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          code: code.toUpperCase(),
          codeList: rawCodes,
          expires: Date.now() + ACCESS_DURATION
        }));
      } catch (e) {}
    }
    if (gateEl)  gateEl.style.display  = 'none';
    if (offerEl) offerEl.style.display = 'block';
    initOffer();
  }

  function showGate() {
    if (gateEl)  gateEl.style.display  = 'block';
    if (offerEl) offerEl.style.display = 'none';
  }

  if (!validCodes.length || isVerified()) {
    grantAccess(null);
  } else {
    showGate();
  }

  function tryCode() {
    if (!codeInput) return;
    const entered = codeInput.value.trim().toUpperCase();
    if (!entered) { codeInput.focus(); return; }
    if (validCodes.includes(entered)) {
      if (errorEl) errorEl.style.display = 'none';
      codeInput.classList.remove('error');
      grantAccess(entered);
    } else {
      if (errorEl) errorEl.style.display = 'block';
      codeInput.classList.add('error');
      codeInput.value = '';
      codeInput.focus();
      setTimeout(() => codeInput.classList.remove('error'), 400);
    }
  }

  if (submitBtn) submitBtn.addEventListener('click', tryCode);
  if (codeInput) {
    codeInput.addEventListener('keydown', e => { if (e.key === 'Enter') tryCode(); });
    codeInput.addEventListener('input',   () => { codeInput.value = codeInput.value.toUpperCase(); });
  }

  // ── Main offer ────────────────────────────────────────────────────────────
  function initOffer() {
    const dataEl = document.getElementById('CircleProducts-' + sid);
    if (!dataEl) return;

    let products = [];
    try { products = JSON.parse(dataEl.textContent.trim()); }
    catch (e) { console.error('Circle products JSON error:', e); return; }
    if (!products.length) return;

    const moneyFormat     = {{ shop.money_format | json }};
    const discountPercent = Number(root.dataset.discountPercent || 0);
    const discountCode    = root.dataset.discountCode || '';
    const buttonAction    = root.dataset.buttonAction || 'cart';
    const activePhase     = Number(root.dataset.activePhase || '0');
    
    // Get all phase discounts from data attributes
    const phase1Discount = Number(root.dataset.phase1Discount || 0);
    const phase2Discount = Number(root.dataset.phase2Discount || 0);
    const phase3Discount = Number(root.dataset.phase3Discount || 0);
    const enablePhase3 = {{ section.settings.enable_phase_3 | default: false | json }};

    const mainReserveBtn   = root.querySelector('[data-reserve-main]');
    const scarcityText     = root.querySelector('[data-scarcity-text]');
    const optionsContainer = root.querySelector('[data-options-container]');
    const previewBox       = root.querySelector('[data-preview-box]');
    const previewImg       = root.querySelector('[data-preview-img]');
    const previewTitle     = root.querySelector('[data-preview-title]');
    const previewVariant   = root.querySelector('[data-preview-variant]');
    const previewSalePrice = root.querySelector('[data-preview-sale-price]');
    const previewWas       = root.querySelector('[data-preview-compare-price]');
    const previewSavings   = root.querySelector('[data-preview-savings]');
    const viewDetailsBtn   = root.querySelector('[data-view-details]');
    const dotsContainer    = root.querySelector('[data-slider-dots]');
    const track            = root.querySelector('[data-slider-track]');
    const viewport         = root.querySelector('[data-slider-viewport]');
    const prevBtn          = root.querySelector('[data-arrow="prev"]');
    const nextBtn          = root.querySelector('[data-arrow="next"]');
    const cards            = root.querySelectorAll('[data-product-index]');
    
    // Get locked row elements
    const lockedPriceAmount = root.querySelector('[data-locked-price-amount]');
    const lockedBadge = root.querySelector('[data-locked-badge]');
    
    // Get strip price elements
    const stripPrice1 = root.querySelector('[data-strip-price="1"]');
    const stripPrice2 = root.querySelector('[data-strip-price="2"]');
    const stripPrice3 = root.querySelector('[data-strip-price="3"]');
    const publicPrice = root.querySelector('[data-strip-price="public"]');

    // Modals
    const productModal    = document.getElementById('circle-product-modal-' + sid);
    const productModalClose = document.getElementById('circle-modal-close-' + sid);
    const sizeModal       = document.getElementById('circle-size-modal-' + sid);
    const sizeModalClose  = document.getElementById('circle-size-close-' + sid);

    let selectedProduct = null;
    let selectedOptions = [];
    let selectedVariant = null;
    let currentSlide    = 0;

    // ── Money formatting ───────────────────────────────────────────────────
    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, moneyFormat);
      }
      const value     = Math.round(Number(cents) || 0);
      const whole     = Math.floor(value / 100);
      const dec       = String(value % 100).padStart(2, '0');
      const withComma = s => String(s).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      return moneyFormat
        .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/g, String(whole).replace(/\B(?=(\d{3})+(?!\d))/g, '.') + ',' + dec)
        .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/g, String(whole).replace(/\B(?=(\d{3})+(?!\d))/g, '.'))
        .replace(/\{\{\s*amount_no_decimals_with_space_separator\s*\}\}/g, String(whole).replace(/\B(?=(\d{3})+(?!\d))/g, ' '))
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/g, withComma(whole))
        .replace(/\{\{\s*amount_with_apostrophe_separator\s*\}\}/g, withComma(whole).replace(/,/g,"'") + '.' + dec)
        .replace(/\{\{\s*amount\s*\}\}/g, withComma(whole) + '.' + dec);
    }

    function discountedPrice(priceCents, customDiscount = null) {
      const disc = customDiscount !== null ? customDiscount : discountPercent;
      if (!disc || disc === 0) return Number(priceCents || 0);
      return Math.round(Number(priceCents || 0) * (100 - disc) / 100);
    }

    // ── Slider functions ───────────────────────────────────────────────────
    function getVisibleCount() { return window.innerWidth <= 480 ? 2 : 4; }
    function maxSlide()        { return Math.max(0, cards.length - getVisibleCount()); }

    function buildDots() {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      const pages = maxSlide() + 1;
      if (pages <= 1) { dotsContainer.style.display = 'none'; return; }
      dotsContainer.style.display = 'flex';
      for (let i = 0; i < pages; i++) {
        const dot = document.createElement('button');
        dot.className = 'circle-slider-dot' + (i === currentSlide ? ' active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
    }

    function updateDots() {
      if (!dotsContainer) return;
      dotsContainer.querySelectorAll('.circle-slider-dot').forEach((d, i) => d.classList.toggle('active', i === currentSlide));
    }

    function goTo(index) {
      const max = maxSlide();
      currentSlide = Math.max(0, Math.min(index, max));
      const allCards = track ? track.querySelectorAll('.circle-prod') : [];
      if (!allCards.length) return;
      const gap       = 10;
      const cardWidth = allCards[0].getBoundingClientRect().width;
      if (track) track.style.transform = `translateX(-${currentSlide * (cardWidth + gap)}px)`;
      if (prevBtn) prevBtn.disabled = currentSlide === 0;
      if (nextBtn) nextBtn.disabled = currentSlide >= max;
      updateDots();
    }

    if (prevBtn) prevBtn.addEventListener('click', () => { if (currentSlide > 0) goTo(currentSlide - 1); });
    if (nextBtn) nextBtn.addEventListener('click', () => { if (currentSlide < maxSlide()) goTo(currentSlide + 1); });

    if (viewport) {
      let touchStartX = 0;
      viewport.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
      viewport.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) { diff > 0 ? goTo(currentSlide + 1) : goTo(currentSlide - 1); }
      }, { passive: true });
    }

    setTimeout(() => { buildDots(); goTo(0); }, 80);
    window.addEventListener('resize', () => { buildDots(); goTo(Math.min(currentSlide, maxSlide())); });

    // ── Update all prices based on selected variant ────────────────────────
function updateAllPrices() {
  if (!selectedVariant) return;
  
  const basePrice = selectedVariant.price;
  
  // Update main price (Your price today) - uses current phase discount
  if (previewSalePrice) {
    const currentPrice = discountedPrice(basePrice);
    previewSalePrice.textContent = formatMoney(currentPrice);
  }
  
  // Update compare price (Public Release)
  if (previewWas) {
    previewWas.textContent = formatMoney(basePrice);
  }
  
  // Update savings text
  if (previewSavings) {
    const currentPrice = discountedPrice(basePrice);
    const savings = basePrice - currentPrice;
    if (discountPercent > 0 && savings > 0) {
      previewSavings.textContent = `Save ${formatMoney(savings)}`;
      previewSavings.style.display = 'inline-block';
    } else {
      previewSavings.style.display = 'none';
    }
  }
  
  // Update Drop Strip Prices (Top Phase Strip)
  const stripCells = root.querySelectorAll('[data-strip-price]');
  stripCells.forEach(cell => {
    const phase = cell.getAttribute('data-strip-price');
    if (phase === 'public') {
      cell.textContent = formatMoney(basePrice);
    } else {
      const phaseDiscount = Number(cell.getAttribute('data-phase-discount') || 0);
      if (phaseDiscount > 0) {
        const discounted = Math.round(basePrice * (100 - phaseDiscount) / 100);
        cell.textContent = formatMoney(discounted);
      } else {
        cell.textContent = formatMoney(basePrice);
      }
    }
  });
  
  // Update Locked Row prices using data-phase-discount attribute
  const lockedPriceContainer = root.querySelector('[data-locked-price]');
  if (lockedPriceContainer) {
    // Find all price amount elements with data-phase-discount
    const priceElements = lockedPriceContainer.querySelectorAll('[data-locked-price-amount], [data-locked-price-amount-2], [data-locked-price-amount-3]');
    
    priceElements.forEach(priceEl => {
      const phaseDiscountAttr = priceEl.getAttribute('data-phase-discount');
      if (phaseDiscountAttr !== null && priceEl.textContent !== 'Closed') {
        const phaseDiscount = Number(phaseDiscountAttr);
        if (phaseDiscount > 0) {
          const discounted = Math.round(basePrice * (100 - phaseDiscount) / 100);
          priceEl.textContent = formatMoney(discounted);
          
          // Update corresponding badge
          let badge = null;
          if (priceEl.hasAttribute('data-locked-price-amount-2')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge-2]');
          } else if (priceEl.hasAttribute('data-locked-price-amount-3')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge-3]');
          } else if (priceEl.hasAttribute('data-locked-price-amount')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge]');
          }
          
          if (badge) {
            badge.textContent = phaseDiscount + '% off';
            badge.style.display = 'inline-block';
          }
        } else if (phaseDiscount === 0) {
          priceEl.textContent = formatMoney(basePrice);
          
          // Update corresponding badge
          let badge = null;
          if (priceEl.hasAttribute('data-locked-price-amount-2')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge-2]');
          } else if (priceEl.hasAttribute('data-locked-price-amount-3')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge-3]');
          } else if (priceEl.hasAttribute('data-locked-price-amount')) {
            badge = lockedPriceContainer.querySelector('[data-locked-badge]');
          }
          
          if (badge) {
            badge.textContent = 'Full price';
            badge.style.display = 'inline-block';
          }
        }
      }
    });
  }
    
  // Update active product card price
  const activeCard = root.querySelector('.circle-prod.active');
  if (activeCard) {
    const priceSpan = activeCard.querySelector('[data-product-price-display]');
    const compareS = activeCard.querySelector('[data-product-compare-price-display]');
    if (priceSpan) {
      priceSpan.textContent = formatMoney(discountedPrice(basePrice));
    }
    if (compareS && discountPercent > 0) {
      compareS.textContent = formatMoney(basePrice);
    }
  }
}

    // ── Product selection ──────────────────────────────────────────────────
    function selectProduct(index) {
      const product = products[index];
      if (!product) return;
      selectedProduct = product;
      cards.forEach(card => card.classList.toggle('active', Number(card.dataset.productIndex) === index));
      const init = product.variants.find(v => v.available) || product.variants[0];
      selectedOptions = init ? [...init.options] : [];
      renderOptions();
      updateSelectedVariant();
    }

    function looksLikeColor(val) {
      const s = document.createElement('span');
      s.style.color = val.toLowerCase().replace(/\s/g, '');
      return s.style.color !== '' || /^#[0-9a-f]{3,8}$/i.test(val);
    }

    function isSizeOption(name) {
      return /size|maat|taille|größe|taglia/i.test(name);
    }

    function renderOptions() {
      if (!optionsContainer || !selectedProduct) return;
      const isDefaultOnly = selectedProduct.variants.length === 1 && selectedProduct.variants[0].title === 'Default Title';
      if (isDefaultOnly) { optionsContainer.innerHTML = ''; return; }

      const hasSizeOption = selectedProduct.options.some(o => isSizeOption(o));

      let html = '<div class="circle-options-inner">';
      html += '<div class="circle-options-header">';
      html += `<div class="circle-options-product-title">${escapeHtml(selectedProduct.title)}</div>`;
      if (hasSizeOption && {{ section.settings.size_guide_content | json }} !== 'null' && {{ section.settings.size_guide_content | json }} !== '') {
        html += `<button type="button" class="circle-size-guide-link" id="circle-size-guide-trigger-${sid}">Size guide</button>`;
      }
      html += '</div>';

      selectedProduct.options.forEach((optName, optIdx) => {
        const values      = [...new Set(selectedProduct.variants.map(v => v.options[optIdx]))];
        const selectedVal = selectedOptions[optIdx];
        html += `<div class="circle-option-group"><div class="circle-option-group-label">${escapeHtml(optName)}<strong>${selectedVal ? ' — ' + escapeHtml(selectedVal) : ''}</strong></div><div class="circle-option-values">`;
        const isSize  = isSizeOption(optName);
        values.forEach(val => {
          const matchingVariants = selectedProduct.variants.filter(v =>
            selectedProduct.options.every((_, i) => i === optIdx ? v.options[i] === val : (selectedOptions[i] == null || v.options[i] === selectedOptions[i]))
          );
          const isAvailable = matchingVariants.some(v => v.available);
          const totalQty    = matchingVariants.reduce((s, v) => s + Number(v.inventory_quantity || 0), 0);
          const isSelected  = selectedOptions[optIdx] === val;
          const isLastUnit  = isAvailable && totalQty > 0 && totalQty <= 5;
          const isColor     = looksLikeColor(val);

          if (isSize) {
            let cls = 'circle-sz';
            if (isSelected)   cls += ' active';
            if (!isAvailable) cls += ' sold-out';
            else if (isLastUnit) cls += ' last-unit';
            html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}"${!isAvailable ? ' disabled' : ''}><span>${escapeHtml(val)}</span><span class="circle-sz-dot"></span></button>`;
          } else {
            let cls = 'circle-option-value-btn';
            if (isSelected)   cls += ' active';
            if (!isAvailable) cls += ' sold-out';
            else if (isLastUnit) cls += ' last-unit';
            if (isColor)      cls += ' is-color';
            if (isColor) {
              html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}" title="${escapeHtml(val)}"><span class="circle-color-swatch" style="background:${val.toLowerCase().replace(/\s/g,'')}"></span></button>`;
            } else {
              html += `<button type="button" class="${cls}" data-opt-idx="${optIdx}" data-opt-val="${escapeHtml(val)}"><span class="circle-option-dot"></span>${escapeHtml(val)}</button>`;
            }
          }
        });
        html += '</div></div>';
      });

      html += '<div class="circle-size-legend"><span><span class="circle-legend-dot last-unit"></span> Last units</span><span><span class="circle-legend-dot sold-out"></span> Sold out</span></div>';
      html += '</div>';
      optionsContainer.innerHTML = html;

      // Bind option buttons
      optionsContainer.querySelectorAll('[data-opt-idx]').forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.classList.contains('sold-out') || btn.disabled) return;
          selectedOptions[Number(btn.dataset.optIdx)] = btn.dataset.optVal;
          renderOptions();
          updateSelectedVariant();
        });
      });

      // Bind size guide trigger
      const sgt = document.getElementById('circle-size-guide-trigger-' + sid);
      if (sgt && sizeModal) {
        sgt.addEventListener('click', () => openModal(sizeModal));
      }
    }
    
    // Helper function to escape HTML
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }

    function updateSelectedVariant() {
      if (!selectedProduct) return;
      let variant = selectedProduct.variants.find(v => v.options.every((optVal, idx) => optVal === selectedOptions[idx]));
      if (!variant) variant = selectedProduct.variants.find(v => v.available) || selectedProduct.variants[0];
      selectedVariant = variant;
      if (!selectedVariant) return;

      // Update all prices based on selected variant
      updateAllPrices();

      // Update card image
      const activeCard = root.querySelector('.circle-prod.active');
      if (activeCard) {
        const cardImg = activeCard.querySelector('[data-product-featured-image]');
        if (cardImg) {
          const src = selectedVariant.featured_image || (selectedProduct.images[0] && selectedProduct.images[0].src);
          if (src) cardImg.src = src;
        }
      }

      // Scarcity text
      const qty = Number(selectedVariant.inventory_quantity || 0);
      if (scarcityText) {
        scarcityText.textContent = !selectedVariant.available
          ? 'This variant is sold out.'
          : (qty > 0 && qty <= 5)
            ? `⚠ Only ${qty} unit${qty !== 1 ? 's' : ''} left in stock`
            : 'Available now — members only.';
      }

      // Update preview box
      if (previewBox) {
        previewBox.style.display = 'flex';
        const imgSrc = selectedVariant.featured_image || (selectedProduct.images[0] && selectedProduct.images[0].src) || '';
        if (previewImg)   { previewImg.src = imgSrc; previewImg.alt = selectedProduct.title; }
        if (previewTitle)   previewTitle.textContent   = selectedProduct.title;
        if (previewVariant) previewVariant.textContent = selectedVariant.title === 'Default Title' ? 'Standard' : selectedVariant.title;
      }

      // Reserve button
      if (mainReserveBtn) {
        mainReserveBtn.disabled = !selectedVariant.available;
        if (!selectedVariant.available) mainReserveBtn.textContent = 'Sold out';
        else if (discountPercent > 0)   mainReserveBtn.textContent = `Reserve — lock in ${discountPercent}% off`;
        else {
          const vLabel = selectedVariant.title === 'Default Title' ? '' : ` — ${selectedVariant.title}`;
          mainReserveBtn.textContent = `Reserve${vLabel}`;
        }
      }
    }

    // ── Reserve / cart ─────────────────────────────────────────────────────
    async function reserveProduct() {
      if (!selectedProduct || !selectedVariant || !selectedVariant.available) return;
      if (buttonAction === 'product') {
        window.location.href = discountCode
          ? `/discount/${encodeURIComponent(discountCode)}?redirect=${encodeURIComponent(selectedProduct.url)}`
          : selectedProduct.url;
        return;
      }
      if (mainReserveBtn) { mainReserveBtn.disabled = true; mainReserveBtn.textContent = 'Adding…'; }
      try {
        const res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: selectedVariant.id, quantity: 1, properties: { '_Circle phase': `Phase ${activePhase}`, '_Circle discount': discountPercent ? `${discountPercent}%` : 'None' } })
        });
        if (!res.ok) throw new Error('Cart error');
        window.location.href = discountCode
          ? `/discount/${encodeURIComponent(discountCode)}?redirect=/cart`
          : '/cart';
      } catch(err) {
        console.error(err);
        if (mainReserveBtn) { mainReserveBtn.disabled = false; mainReserveBtn.textContent = 'Try again'; }
      }
    }

    cards.forEach(card => card.addEventListener('click', () => selectProduct(Number(card.dataset.productIndex))));
    if (mainReserveBtn) mainReserveBtn.addEventListener('click', reserveProduct);

    // ── Product details modal ──────────────────────────────────────────────
    function openProductModal(product, variant) {
      if (!productModal) return;
      const imgTrack  = productModal.querySelector('[data-modal-img-track]');
      const imgPrev   = productModal.querySelector('[data-modal-img-prev]');
      const imgNext   = productModal.querySelector('[data-modal-img-next]');
      const imgDots   = productModal.querySelector('[data-modal-img-dots]');
      const modalLabel= productModal.querySelector('[data-modal-label]');
      const modalTitle= productModal.querySelector('[data-modal-title]');
      const modalSale = productModal.querySelector('[data-modal-sale]');
      const modalWas  = productModal.querySelector('[data-modal-was]');
      const modalSave = productModal.querySelector('[data-modal-save]');
      const modalDesc = productModal.querySelector('[data-modal-desc]');

      const images = product.images && product.images.length ? product.images : [];
      let modalImgIdx = 0;

      let orderedImgs = [...images];
      if (variant && variant.featured_image) {
        orderedImgs = [{ src: variant.featured_image, alt: product.title }, ...images.filter(i => i.src !== variant.featured_image)];
      }

      if (imgTrack) {
        imgTrack.innerHTML = orderedImgs.map(img =>
          `<img src="${img.src}" alt="${img.alt || product.title}" loading="lazy">`
        ).join('');
        imgTrack.style.transform = 'translateX(0)';
      }

      function goModalImg(idx) {
        modalImgIdx = Math.max(0, Math.min(idx, orderedImgs.length - 1));
        if (imgTrack) imgTrack.style.transform = `translateX(-${modalImgIdx * 100}%)`;
        if (imgDots) imgDots.querySelectorAll('.circle-modal-img-dot').forEach((d, i) => d.classList.toggle('active', i === modalImgIdx));
        if (imgPrev) imgPrev.style.display = modalImgIdx > 0 ? 'flex' : 'none';
        if (imgNext) imgNext.style.display = modalImgIdx < orderedImgs.length - 1 ? 'flex' : 'none';
      }

      if (imgDots) {
        imgDots.innerHTML = orderedImgs.length > 1
          ? orderedImgs.map((_, i) => `<button type="button" class="circle-modal-img-dot${i === 0 ? ' active' : ''}" aria-label="Image ${i+1}"></button>`).join('')
          : '';
        imgDots.querySelectorAll('.circle-modal-img-dot').forEach((d, i) => d.addEventListener('click', () => goModalImg(i)));
      }
      if (imgPrev) { imgPrev.onclick = () => goModalImg(modalImgIdx - 1); imgPrev.style.display = 'none'; }
      if (imgNext) { imgNext.onclick = () => goModalImg(modalImgIdx + 1); imgNext.style.display = orderedImgs.length > 1 ? 'flex' : 'none'; }

      if (imgTrack) {
        let tStart = 0;
        imgTrack.addEventListener('touchstart', e => { tStart = e.touches[0].clientX; }, { passive: true });
        imgTrack.addEventListener('touchend', e => {
          const diff = tStart - e.changedTouches[0].clientX;
          if (Math.abs(diff) > 40) { diff > 0 ? goModalImg(modalImgIdx + 1) : goModalImg(modalImgIdx - 1); }
        }, { passive: true });
      }

      if (modalLabel) modalLabel.textContent = discountPercent > 0 ? `${discountPercent}% off for Circle members` : 'Circle Members Only';
      if (modalTitle) modalTitle.textContent = product.title;
      const currentPrice  = variant ? discountedPrice(variant.price) : discountedPrice(product.price);
      const originalPrice = variant ? variant.price : product.price;
      const savings       = originalPrice - currentPrice;
      if (modalSale) modalSale.textContent = formatMoney(currentPrice);
      if (modalWas)  modalWas.textContent  = discountPercent > 0 ? formatMoney(originalPrice) : '';
      if (modalSave) { modalSave.textContent = discountPercent > 0 ? `Save ${formatMoney(savings)}` : ''; modalSave.style.display = discountPercent > 0 ? 'inline-block' : 'none'; }
      if (modalDesc) modalDesc.textContent = product.description || '';

      openModal(productModal);
    }

    if (viewDetailsBtn) {
      viewDetailsBtn.addEventListener('click', e => {
        e.preventDefault();
        if (selectedProduct) openProductModal(selectedProduct, selectedVariant);
      });
    }

    // ── Modal helpers ──────────────────────────────────────────────────────
    function openModal(modal) {
      if (!modal) return;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => modal.querySelector('.circle-modal').style.animation = `circleModalIn-{{ sid }} .28s cubic-bezier(.25,1,.5,1)`);
    }

    function closeModal(modal) {
      if (!modal) return;
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    if (productModalClose) productModalClose.addEventListener('click', () => closeModal(productModal));
    if (sizeModalClose)    sizeModalClose.addEventListener('click',    () => closeModal(sizeModal));

    [productModal, sizeModal].forEach(modal => {
      if (!modal) return;
      modal.addEventListener('click', e => { if (e.target === modal) closeModal(modal); });
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeModal(productModal);
        closeModal(sizeModal);
      }
    });

    // ── Countdown ──────────────────────────────────────────────────────────
    function updateCountdown() {
      const endMs = Number(root.dataset.activeEndMs || 0);
      if (!endMs) return;
      const diff = Math.max(0, endMs - Date.now());
      const pad  = n => String(n).padStart(2, '0');
      const set  = (sel, val) => { const el = root.querySelector(sel); if (el) el.textContent = pad(val); };
      set('[data-days]',    Math.floor(diff / 86400000));
      set('[data-hours]',   Math.floor((diff % 86400000) / 3600000));
      set('[data-minutes]', Math.floor((diff % 3600000) / 60000));
      set('[data-seconds]', Math.floor((diff % 60000) / 1000));
      if (diff <= 0 && mainReserveBtn) { mainReserveBtn.disabled = true; mainReserveBtn.textContent = 'Offer ended'; }
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Initialize with first product
    selectProduct(0);
  } // end initOffer()

})();

// Waitlist webhook
document.addEventListener('DOMContentLoaded', function() {
  ['circle-waitlist-form', 'circle-gate-waitlist-form'].forEach(function(formId) {
    const form = document.getElementById(formId);
    if (!form) return;
    form.addEventListener('submit', function() {
      const emailField = form.querySelector('input[name="contact[email]"]');
      if (!emailField) return;
      fetch('https://flow-webhooks.k8s.eu.codecreationlabs.cloud/webhook/77vz1k5x', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Api-Key': '616b1377177c202d5h780f5d206c5c1o790g3731631g7r0d215p3q3s641o3d0j' },
        body: JSON.stringify({ email: emailField.value, source: 'circle-waitlist' })
      })
      .then(r => r.json())
      .then(d => console.log('Webhook Success:', d))
      .catch(e => console.error('Webhook Error:', e));
    });
  });
});
</script>

