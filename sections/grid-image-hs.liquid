
{% liquid
  assign id = section.id
%}

<style>
  .sec-{{ id }} {
    box-sizing: border-box;
    margin-top: {{ section.settings.margin_top | append: 'px' }};
    margin-bottom: {{ section.settings.margin_bottom | append: 'px' }};
    padding-top: {{ section.settings.padding_top | append: 'px' }};
    padding-bottom: {{ section.settings.padding_bottom | append: 'px' }};
  }

  .wrapper-{{ id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(1, {{ section.settings.max_height | append: 'px' }});
    max-height: {{ section.settings.max_height | append: 'px'  }};
    gap: 16px;
  }

  .wrapper-{{ id }} .container__ {
    display: flex;
    flex-direction: column;
    line-height: 0;
    gap: 16px;
  }

  .wrapper-{{ id }} .image__wraper {
    position: relative;
    line-height: 0;
    height: 100%;
    overflow: hidden;
  }

  .wrapper-{{ id }} .image__wraper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wrapper-{{ id }} .absolute__link {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* First Column - spans rows 1-3 */
  .wrapper-{{ id }} .1st__column__ {
    grid-column: 1;
    grid-row: 1 / 4;
  }

  .wrapper-{{ id }} .1st__column__ .loop_count-1 {
    flex: 1;
  }

  /* Second Column */
  .wrapper-{{ id }} .2nd__column__ {
    grid-column: 2;
    grid-row: 1 / 4;
  }

  .wrapper-{{ id }} .2nd__column__ .loop_count-1 {
    flex: 2;
  }

  .wrapper-{{ id }} .2nd__column__ .loop_count-2 {
    flex: 1;
  }

  /* Third Column */
  .wrapper-{{ id }} .3rd__column__ {
    grid-column: 3;
    grid-row: 1 / 4;
  }

  .wrapper-{{ id }} .3rd__column__ .loop_count-1 {
    flex: 1;
  }

  .wrapper-{{ id }} .3rd__column__ .loop_count-2 {
    flex: 2;
  }

  @media (max-width: 600px) {
    .sec-{{ id }} {
      margin-top: {{ section.settings.margin_top_m | append: 'px' }};
      margin-bottom: {{ section.settings.margin_bottom_m | append: 'px' }};
      padding-top: {{ section.settings.padding_top_m | append: 'px' }};
      padding-bottom: {{ section.settings.padding_bottom_m | append: 'px' }};
    }

    .wrapper-{{ id }} {
      {% comment %} grid-template-columns: 1fr; {% endcomment %}
      grid-template-rows: auto;
      max-height: none;
    }

    .wrapper-{{ id }} .1st__column__,
    .wrapper-{{ id }} .2nd__column__,
    .wrapper-{{ id }} .3rd__column__ {
      grid-column: 1;
      grid-row: auto;
    }

    .wrapper-{{ id }} .image__wraper {
      min-height: 200px;
    }
  }
</style>

<div class="sec-{{ id }}">
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
    <div class="wrapper-{{ id }}">
      <div class="1st__column__ container__">
        {% assign counter = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'first_column' %}
            {% assign counter = counter | plus: 1 %}
            <div class="image__wraper loop_count-{{ counter }}">
              {% if block.settings.link != blank %}
                <a class="absolute__link" href="{{ block.settings.link }}" aria-label="View {{ block.settings.image.alt | default: 'image' }}"></a>
              {% endif %}
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="2nd__column__ container__">
        {% assign counter_ = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'second_column' %}
            {% assign counter_ = counter_ | plus: 1 %}
            <div class="image__wraper loop_count-{{ counter_ }}">
              {% if block.settings.link != blank %}
                <a class="absolute__link" href="{{ block.settings.link }}" aria-label="View {{ block.settings.image.alt | default: 'image' }}"></a>
              {% endif %}
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="3rd__column__ container__">
        {% assign counter__ = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'third_column' %}
            {% assign counter__ = counter__ | plus: 1 %}
            <div class="image__wraper loop_count-{{ counter__ }}">
              {% if block.settings.link != blank %}
                <a class="absolute__link" href="{{ block.settings.link }}" aria-label="View {{ block.settings.image.alt | default: 'image' }}"></a>
              {% endif %}
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Grid Image",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width Section",
      "default": false
    },
    {
      "type": "range",
      "step": 10,
      "id": "max_height",
      "label": "Max height",
      "default": 900,
      "min": 600,
      "max": 1600,
    },
    {
      "type": "header",
      "content": "Section Spacing Desktop"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "Section Spacing Mobile"
    },
    {
      "type": "range",
      "id": "margin_top_m",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_m",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "first_column",
      "name": "First Column",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "second_column",
      "name": "Second Column",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "third_column",
      "name": "Third Column",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grid Image"
    }
  ]
}
{% endschema %}