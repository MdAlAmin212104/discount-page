{% comment %}
  Product Tabs Section - "You May Also Like"
  Displays products in tabs with navigation
{% endcomment %}

{%- style -%}
  .product-tabs {
    padding: 40px 0;
    width: 100%;
  }
  
  .product-tabs__heading {
    text-align: center;
    margin-bottom: 15px;
    font-size: 1.2rem;
    font-weight: 600;
  }
  .product-tabs__content {
    margin: 0px 10px;
}
.product-card__image img {
    border: 1px solid;
}

  .product-tabs__nav {
    display: flex;
    justify-content: center;
    border-bottom: 1px solid #e8e8e8;
    margin-bottom: 30px;
  }

  .product-tabs__tab {
    padding: 10px 15px;
    margin: 0 5px;
    cursor: pointer;
    font-size: 0.85rem;
    position: relative;
    background: none;
    border: none;
    color: #000000;
  }
.product-card__image img {
    border-radius: 16px;
}
  .product-tabs__tab.active {
    color: #000000;
    font-weight: 600;
  }

  .product-tabs__tab.active:after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #000000;
  }

  .product-tabs__content {
    display: none;
  }

  .product-tabs__content.active {
    display: block;
  }

  .product-tabs__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
  }

  @media screen and (max-width: 990px) {
    .product-tabs__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .product-tabs__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .product-card {
    position: relative;
  }

  .product-card__image {
    position: relative;
    padding-bottom: 10px;
  }

  .product-card__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .product-card__add {
    position: absolute;
    bottom: 20px;
    right: 10px;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #000;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .product-card:hover .product-card__add {
    opacity: 1;
  }

  .product-card__details {
    text-align: center;
    padding: 10px 0;
  }

  .product-card__title {
    font-size: 0.9rem;
    margin-bottom: 5px;
    color: #000000;
    text-decoration: none;
  }

  .product-card__color {
    font-size: 0.8rem;
    color: #6b6b6b;
    margin-bottom: 5px;
  }

  .product-card__price {
    font-size: 0.9rem;
    color: #000000;
  }
{%- endstyle -%}

<div class="product-tabs">
  <h2 class="product-tabs__heading">{{ section.settings.heading }}</h2>
  
  <div class="product-tabs__nav">
    {% for block in section.blocks %}
      {% if block.type == 'tab' %}
        <button class="product-tabs__tab{% if forloop.first %} active{% endif %}" data-tab="{{ block.id }}">
          {{ block.settings.title }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  {% for block in section.blocks %}
    {% if block.type == 'tab' %}
      <div id="{{ block.id }}" class="product-tabs__content{% if forloop.first %} active{% endif %}">
        <div class="product-tabs__grid">
          {% assign collection = collections[block.settings.collection] %}
          {% for product in collection.products limit: block.settings.products_limit %}
            <div class="product-card">
              <div class="product-card__image">
                <a href="{{ product.url }}">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | img_url: '' }}" alt="{{ product.title | escape }}">
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {% endif %}
                </a>
                <button class="product-card__add" aria-label="Add to cart">+</button>
              </div>
              <div class="product-card__details">
                <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>
                <div class="product-card__color">
                  {{ product.metafields.my_fields.color | default: product.type }}
                  {% if product.metafields.my_fields.color_count %}
                    · {{ product.metafields.my_fields.color_count }} Colours
                  {% endif %}
                </div>
                <div class="product-card__price">
                  {% if product.compare_at_price > product.price %}
                    <span class="product-card__price--sale">{{ product.price | money }}</span>
                    <s>{{ product.compare_at_price | money }}</s>
                  {% else %}
                    <span>{{ product.price | money }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.product-tabs__tab');
    const contents = document.querySelectorAll('.product-tabs__content');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active class from all tabs
        tabs.forEach(t => t.classList.remove('active'));
        // Add active class to clicked tab
        tab.classList.add('active');
        
        // Hide all content
        contents.forEach(content => content.classList.remove('active'));
        // Show content for clicked tab
        const contentId = tab.getAttribute('data-tab');
        document.getElementById(contentId).classList.add('active');
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YOU MAY ALSO LIKE"
    },
    {
      "type": "select",
      "id": "grid_columns_desktop",
      "label": "Columns on desktop",
      "default": "5",
      "options": [
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        }
      ]
    },
    {
      "type": "select",
      "id": "grid_columns_mobile",
      "label": "Columns on mobile",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Product Tab",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Title",
          "default": "SUGGESTED"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "range",
          "id": "products_limit",
          "label": "Products limit",
          "min": 4,
          "max": 20,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Tabs",
      "blocks": [
        {
          "type": "tab",
          "settings": {
            "title": "SUGGESTED"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "T-SHIRTS"
          }
        },
        {
          "type": "tab",
          "settings": {
            "title": "HOODIES"
          }
        }
      ]
    }
  ]
}
{% endschema %}