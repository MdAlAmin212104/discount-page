{% comment %}
  Custom Footer Section for Shopify
  File: sections/custom-footer.liquid
  Updated with working mobile accordion functionality
{% endcomment %}

<footer class="custom-footer" data-section-id="{{ section.id }}">
  <!-- Main Footer Content -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">
        <!-- Logo Block -->
        {% if section.settings.show_logo %}
          <div class="footer-column footer-logo">
            {% if section.settings.logo %}
              <img
                src="{{ section.settings.logo | img_url: '200x' }}"
                alt="{{ shop.name }}"
                class="footer-logo-img"
                width="120"
                height="auto"
              >
            {% else %}
              <h3 class="footer-logo-text">{{ shop.name }}</h3>
            {% endif %}
          </div>
        {% endif %}

        <!-- Dynamic Menu Blocks -->
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'menu_column' %}
              <div class="footer-column footer-accordion-item" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <div class="footer-accordion-header">
                    <h4 class="footer-heading">{{ block.settings.heading }}</h4>
                    <span class="footer-accordion-arrow">›</span>
                  </div>
                {% endif %}

                {% if block.settings.menu != blank %}
                  <div class="footer-accordion-content">
                    <ul class="footer-menu">
                      {% for link in linklists[block.settings.menu].links %}
                        <li class="footer-menu-item">
                          <a href="{{ link.url }}" class="footer-menu-link">
                            {{ link.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </div>

            {% when 'newsletter' %}
              <div class="footer-column footer-newsletter footer-accordion-item" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <div class="footer-accordion-header">
                    <h4 class="footer-heading">{{ block.settings.heading }}</h4>
                    <span class="footer-accordion-arrow">›</span>
                  </div>
                {% endif %}

                <div class="footer-accordion-content">
                  {% if block.settings.description != blank %}
                    <p class="newsletter-description">{{ block.settings.description }}</p>
                  {% endif %}

                  {% form 'customer', class: 'newsletter-form' %}
                    {% if form.posted_successfully? %}
                      <div class="newsletter-success" id="newsletter-success-{{ block.id }}">
                        <p>{{ 'general.newsletter_form.confirmation' | t }}</p>
                      </div>
                    {% endif %}

                    <div
                      class="newsletter-input-wrapper"
                      id="newsletter-form-{{ block.id }}"
                      {% if form.posted_successfully? %}
                        style="display: none;"
                      {% endif %}
                    >
                      <input
                        type="email"
                        name="contact[email]"
                        placeholder="{{ block.settings.placeholder | default: 'Enter email address' }}"
                        class="newsletter-input"
                        required
                        autocomplete="email"
                      >
                      <button type="submit" class="newsletter-submit" aria-label="Subscribe">
                        <svg
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path d="M5 12h14M12 5l7 7-7 7"/>
                        </svg>
                      </button>
                    </div>
                    <input type="hidden" name="contact[tags]" value="newsletter">

                    {% if block.settings.show_privacy_text %}
                      <p
                        class="newsletter-privacy"
                        id="newsletter-privacy-{{ block.id }}"
                        {% if form.posted_successfully? %}
                          style="display: none;"
                        {% endif %}
                      >
                        {% if block.settings.privacy_text != blank %}
                          {{ block.settings.privacy_text }}
                        {% else %}
                          I have read and understand Casablanca's Privacy Policy and I agree to receive the newsletter
                          and other marketing communications.
                        {% endif %}
                      </p>
                    {% endif %}

                    {% if form.posted_successfully? %}
                      <script>
                        setTimeout(function () {
                          const successElement = document.getElementById('newsletter-success-{{ block.id }}');
                          const formElement = document.getElementById('newsletter-form-{{ block.id }}');
                          const privacyElement = document.getElementById('newsletter-privacy-{{ block.id }}');

                          if (successElement) successElement.style.display = 'none';
                          if (formElement) formElement.style.display = 'flex';
                          if (privacyElement) privacyElement.style.display = 'block';
                        }, 5000);
                      </script>
                    {% endif %}

                    {% if form.errors %}
                      <div class="newsletter-error">
                        {{ form.errors | default_errors }}
                      </div>
                    {% endif %}
                  {% endform %}
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </div>
  </div>

    <div>
    <div style="text-align: center">
      <img
        src="https://cdn.shopify.com/s/files/1/1494/6308/files/image.png?v=1761722361"
        alt="Shopify image"
        style="width: 80px; height: auto; display: inline-block"
      >
    </div>

