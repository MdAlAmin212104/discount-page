<style>
  .custom-footer {
    background-color: rgb(0, 56, 47);
    color: #ffffff;
  }

  #shopify-section-custom-footer input.newsletter-input {
    width: 50% !important;
  }

  .container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .footer-main {
    padding: 60px 0 40px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px 60px;
    align-items: start;
  }

  .footer-column {
    min-width: 0;
  }

  .footer-logo-img {
    max-width: 120px;
    height: auto;
    filter: brightness(0) invert(1);
  }

  .footer-logo-text {
    font-size: 24px;
    font-weight: 300;
    margin: 0;
    color: #ffffff;
  }

  .footer-heading {
    font-size: 16px;
    font-weight: 400;
    margin: 0;
    color: white;
    text-transform: None;
    letter-spacing: 0.5px;
  }

  .footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-menu-item {
    margin-bottom: 12px;
  }

  .footer-menu-link {
    color: white;
    text-decoration: none;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 300;
    transition: color 0.3s ease;
  }

  .footer-menu-link:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-newsletter {
    max-width: 350px;
  }

  .newsletter-description {
    color: White;
    font-size: 12px;
    line-height: 1.5;
    margin: 0 0 20px 0;
  }

  .newsletter-form {
    margin-bottom: 15px;
  }

  .newsletter-input-wrapper {
    position: relative;
    display: flex;
    margin-bottom: 15px;
  }

  .newsletter-input {
    flex: 1;
    padding: 12px 50px 12px 15px;
    border: 1px solid #f4fffb;
    border-radius: 50px !important;
    background-color: rgb(255 255 255 / 0%);
    color: #ffffff;
    font-size: 14px;
    outline: none;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .newsletter-input::placeholder {
    color: white;
    opacity: 0.8;
  }

  .newsletter-input:focus {
    border-color: #4a7c59;
    background-color: rgba(255, 255, 255, 0.15);
  }

  .newsletter-submit {
    position: absolute;
    right: 5px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #b8d4c8;
    cursor: pointer;
    padding: 8px;
    border-radius: 4px;
    transition: color 0.3s ease;
  }

  .newsletter-submit:hover {
    color: #ffffff;
  }

  .newsletter-privacy {
    font-size: 12px;
    color: white;
    line-height: 1.4;
    margin: 0;
    opacity: 0.8;
  }

  .newsletter-success,
  .newsletter-error {
    padding: 10px;
    border-radius: 4px;
    font-size: 14px;
    margin-bottom: 15px;
  }

  .newsletter-success {
    background-color: rgba(76, 175, 80, 0.2);
    color: #4caf50;
    border: 1px solid rgba(76, 175, 80, 0.3);
  }

  .newsletter-error {
    background-color: rgba(244, 67, 54, 0.2);
    color: #f44336;
    border: 1px solid rgba(244, 67, 54, 0.3);
  }

  .footer-bottom {
    border-top: 1px solid #2d5a4a;
    padding: 14px 0;
  }

  .footer-bottom-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
  }

  .footer-copyright {
    text-align: center;
    flex: 1;
  }

  .footer-copyright p {
    margin: 0;
    font-size: 12px;
    color: white;
    opacity: 0.8;
  }

  /* Desktop Styles - Accordion headers not clickable */
  .footer-accordion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0;
    background: none;
    border: none;
    width: 100%;
  }

  .footer-accordion-arrow {
    font-size: 18px;
    color: white;
    transition: transform 0.3s ease;
    display: none;
  }

  .footer-accordion-content {
    display: block;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .footer-main {
      padding: 40px 0 30px;
    }

    .footer-copyright p {
      font-size: 12px !important;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0;
      text-align: left;
    }

    .footer-newsletter {
      max-width: 100%;
    }

    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
      gap: 15px;
    }

    /* Accordion Mobile Styles */
    .footer-accordion-item {
      border-bottom: 1px solid #2d5a4a;
      padding: 16px 0;
    }

    .footer-accordion-header {
      cursor: pointer;
      padding: 0;
      margin: 0;
      user-select: none;
    }

    .footer-accordion-arrow {
      display: block;
      font-size: 20px;
      font-weight: bold;
    }

    .footer-accordion-content {
      display: none;
      padding-top: 16px;
      animation: fadeIn 0.3s ease;
    }

    .footer-accordion-item.active .footer-accordion-content {
      display: block;
    }

    .footer-accordion-item.active .footer-accordion-arrow {
      transform: rotate(90deg);
    }

    .footer-logo {
      border-bottom: 1px solid #2d5a4a;
      padding-bottom: 20px;
      margin-bottom: 10px;
      text-align: center;
    }

    .footer-logo .footer-accordion-header {
      cursor: default;
      justify-content: center;
    }

    .footer-logo .footer-accordion-arrow {
      display: none !important;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 15px;
    }

    .footer-main {
      padding: 30px 0 20px;
    }

    .footer-heading {
      font-size: 14px;
    }

    .footer-menu-link {
      font-size: 13px;
    }

    .newsletter-input {
      padding: 10px 45px 10px 12px;
      font-size: 13px;
    }

    .newsletter-privacy {
      font-size: 10px;
    }

    .footer-accordion-item {
      padding: 12px 0;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }


  .footer-column.footer-logo {
    margin-bottom: 0px !important;
}
</style>

<script>
  (function () {
    // Wait for DOM to be fully loaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooterAccordion);
    } else {
      initFooterAccordion();
    }

    function initFooterAccordion() {
      const accordionItems = document.querySelectorAll('.footer-accordion-item');

      // Only initialize accordion on mobile
      function setupAccordion() {
        if (window.innerWidth <= 768) {
          accordionItems.forEach((item) => {
            // Skip logo section
            if (item.classList.contains('footer-logo')) return;

            const header = item.querySelector('.footer-accordion-header');
            const content = item.querySelector('.footer-accordion-content');

            if (header && content) {
              // Remove any existing event listeners
              header.replaceWith(header.cloneNode(true));
              const newHeader = item.querySelector('.footer-accordion-header');

              newHeader.addEventListener('click', function () {
                // Close other open items
                accordionItems.forEach((otherItem) => {
                  if (otherItem !== item && otherItem.classList.contains('active')) {
                    otherItem.classList.remove('active');
                  }
                });

                // Toggle current item
                item.classList.toggle('active');
              });
            }
          });
        } else {
          // On desktop, remove active classes and event listeners
          accordionItems.forEach((item) => {
            item.classList.remove('active');
            const header = item.querySelector('.footer-accordion-header');
            if (header) {
              header.replaceWith(header.cloneNode(true));
            }
          });
        }
      }

      // Initial setup
      setupAccordion();

      // Re-setup on window resize
      let resizeTimeout;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(setupAccordion, 250);
      });
    }
  })();
</script>

